@page "/"
@page "/feed"
@using BuildSmart.Maui.ViewModels
@using System.ComponentModel
@layout BuildSmart.Maui.Components.Layout.MainLayout
@implements IDisposable
@inject FeedPageViewModel ViewModel

<ErrorBoundary>
    <ChildContent>
        @if (ViewModel == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="container-fluid py-3" style="min-height: 100vh;">
                <!-- Homeowner Action Header -->
                @if (ViewModel.IsHomeowner)
                {
                    <button class="btn btn-primary w-100 fw-bold mb-4 shadow-sm" style="border-radius: 8px; padding: 12px;" @onclick="() => ViewModel.NavigateToWizardCommand.Execute(null)">
                        + Start New Project
                    </button>
                }

                <!-- Tradesman Feed Header -->
                @if (ViewModel.IsTradesman)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                        <h2 class="h5 fw-bold mb-0">Available Auctions</h2>
                        <a href="#" class="text-primary text-decoration-underline" style="font-size: 0.85rem;" @onclick="() => ViewModel.NavigateToPassedAuctionsCommand.Execute(null)" @onclick:preventDefault>
                            Dismissed Jobs
                        </a>
                    </div>
                }

                <!-- Loading Indicator -->
                @if (ViewModel.IsLoading)
                {
                    <div class="text-center my-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else
                {
                    <!-- 1. Homeowner View: Pros Directory -->
                    @if (ViewModel.IsHomeowner && ViewModel.Tradesmen != null)
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var tradesman in ViewModel.Tradesmen)
                            {
                                <div class="card border-0 shadow-sm rounded-4" style="cursor: pointer;" @onclick="() => ViewModel.NavigateToDetailsCommand.Execute(tradesman)">
                                    <div class="card-body p-3">
                                        <div class="d-flex mb-2">
                                            <img src="@(string.IsNullOrEmpty(tradesman.User?.ProfilePictureUrl) ? "dotnet_bot.png" : tradesman.User.ProfilePictureUrl)" 
                                                 class="rounded-circle me-3" 
                                                 style="width: 50px; height: 50px; object-fit: cover;" 
                                                 alt="Profile Picture" />
                                            <div class="flex-grow-1">
                                                <h5 class="fw-bold mb-0" style="font-size: 1rem;">@tradesman.User?.FirstName</h5>
                                                <small class="text-muted">Professional</small>
                                            </div>
                                            <div class="align-self-start bg-primary bg-opacity-10 px-2 py-1 rounded">
                                                <span class="text-primary fw-bold" style="font-size: 0.75rem;">⭐ @string.Format("{0:F1}", tradesman.AverageRating)</span>
                                            </div>
                                        </div>
                                        <p class="text-dark mb-2" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                            @tradesman.User?.Bio
                                        </p>
                                        <div class="d-flex align-items-center">
                                            <span class="me-1" style="font-size: 0.8rem;">📍</span>
                                            <small class="text-muted">@tradesman.User?.Location</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- 2. Tradesman View: Available Auctions Feed -->
                    @if (ViewModel.IsTradesman && ViewModel.Auctions != null)
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var auction in ViewModel.Auctions)
                            {
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body p-3">
                                        <!-- Job Header -->
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h5 class="fw-bold mb-0" style="font-size: 1.1rem;">@auction.Job?.Title</h5>
                                                <small class="text-primary d-block">@auction.Job?.ServiceCategory?.Name</small>
                                            </div>
                                            <span class="fw-bold text-success" style="font-size: 1.1rem;">
                                                @(auction.Job?.EstimatedBudget != null ? string.Format("{0:C0}", auction.Job.EstimatedBudget.Total) : "N/A")
                                            </span>
                                        </div>

                                        <!-- Details -->
                                        <p class="mb-3" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @auction.Job?.Description
                                        </p>
                                        
                                        <div class="d-flex gap-4 mb-3">
                                            <div class="d-flex align-items-center">
                                                <span class="me-1" style="font-size: 0.8rem;">📍</span>
                                                <small class="text-muted">@auction.Job?.Location</small>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="me-1" style="font-size: 0.8rem;">💬</span>
                                                <small class="text-muted">@auction.Questions?.Count questions</small>
                                            </div>
                                        </div>

                                        <!-- Actions -->
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-outline-secondary w-50 py-2" style="border-radius: 8px;" @onclick="() => ViewModel.PassAuctionCommand.Execute(auction)">
                                                Pass
                                            </button>
                                            <button class="btn btn-primary w-50 py-2" style="border-radius: 8px;" @onclick="() => ViewModel.NavigateToDetailsCommand.Execute(auction)">
                                                View &amp; Bid
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3">
            <h4>Rendering Error</h4>
            <p>@context.Message</p>
            <pre style="font-size: 10px; overflow-x: auto;">@context.StackTrace</pre>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged += OnViewModelPropertyChanged;
            await ViewModel.LoadFeedCommand.ExecuteAsync(null);
        }
    }

    private async void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }
}
