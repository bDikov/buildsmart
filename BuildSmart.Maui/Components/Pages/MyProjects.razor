@page "/my-projects"
@using BuildSmart.Maui.ViewModels
@inject MyProjectsViewModel ViewModel

<div class="projects-container">
    <div class="header-section">
        <h2 class="page-title">My Projects</h2>
        <button class="bs-btn-primary" @onclick="ViewModel.CreateProjectCommand.ExecuteAsync">
            Create Project
        </button>
    </div>

    @if (ViewModel.IsBusy && !ViewModel.Projects.Any())
    {
        <div class="loading-state">
            <p>Loading projects...</p>
        </div>
    }
    else if (ViewModel.IsEmpty)
    {
        <div class="empty-state card-light">
            <p>You haven't posted any projects yet.</p>
            <button class="bs-btn-primary" @onclick="ViewModel.CreateProjectCommand.ExecuteAsync">Create Project</button>
        </div>
    }
    else
    {
        <div class="projects-list">
            @foreach (var project in ViewModel.Projects)
            {
                <div class="bs-card project-card" @onclick="() => ViewModel.GoToDetailsCommand.Execute(project)">
                    <div class="project-header">
                        <h3>@(string.IsNullOrEmpty(project.Title) ? "(No Title)" : project.Title)</h3>
                        <span class="status-badge status-@project.Status.ToString().ToLower()">@project.Status</span>
                    </div>
                    
                    <p class="project-desc">@(string.IsNullOrEmpty(project.Description) ? "(No Description)" : project.Description)</p>
                    
                    <hr class="divider" />
                    
                    <div class="jobs-section">
                        <h4>Jobs:</h4>
                        @if (project.JobPosts == null || !project.JobPosts.Any())
                        {
                            <p class="no-jobs">No specific jobs added.</p>
                        }
                        else
                        {
                            <div class="jobs-list">
                                @foreach (var job in project.JobPosts)
                                {
                                    <div class="job-item">
                                        <div class="job-info">
                                            <span class="job-category">@(job.ServiceCategory?.Name ?? "Unknown Category")</span>
                                            <span class="job-title">@job.Title</span>
                                        </div>
                                        <span class="job-status">@job.Status</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="project-actions">
                        <button class="bs-btn-dark btn-sm" @onclick:stopPropagation="true" @onclick="() => ViewModel.DeleteProjectCommand.ExecuteAsync(project)">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .projects-container {
        padding: 20px;
        font-family: var(--font-primary);
        max-width: 800px;
        margin: 0 auto;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .page-title {
        font-family: var(--font-heading);
        color: var(--text-primary);
        font-size: 32px;
        margin: 0;
    }

    .loading-state, .empty-state {
        text-align: center;
        padding: 50px 20px;
    }

    .empty-state {
        padding: 60px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }

    .empty-state p {
        color: var(--text-secondary);
        font-size: 18px;
        margin: 0;
    }

    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .project-card {
        padding: 24px;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        position: relative;
    }

    .project-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-hover);
    }

    .project-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
    }

    .project-header h3 {
        font-family: var(--font-primary);
        font-size: 20px;
        color: var(--text-primary);
        margin: 0;
        font-weight: 700;
    }

    .status-badge {
        font-size: 12px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 12px;
        background-color: #e0e0e0;
        color: #333;
    }

    .status-draft { background-color: #f1f3f5; color: #6c757d; }
    .status-open { background-color: #e3f2fd; color: #0d6efd; }
    .status-inprogress { background-color: #fff3cd; color: #0dcaf0; }
    .status-completed { background-color: #d1e7dd; color: #198754; }

    .project-desc {
        color: var(--text-secondary);
        font-size: 14px;
        margin: 0 0 15px 0;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .divider {
        border: none;
        height: 1px;
        background-color: var(--border-color);
        margin: 15px 0;
    }

    .jobs-section h4 {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 10px 0;
    }

    .no-jobs {
        font-size: 12px;
        font-style: italic;
        color: var(--text-secondary);
        margin: 0;
    }

    .jobs-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .job-item {
        background-color: var(--bg-page);
        border-radius: 8px;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .job-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .job-category {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .job-title {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .job-status {
        font-size: 12px;
        font-weight: 700;
        color: #ff9800; /* Orange highlight like in XAML */
    }

    .project-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 15px;
    }

    .btn-sm {
        padding: 8px 16px;
        font-size: 14px;
        background-color: #dc3545; /* Red for delete */
        color: white;
    }

    .btn-sm:hover {
        background-color: #c82333;
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (ViewModel.Projects.Count == 0)
        {
            await ViewModel.LoadProjectsAsync();
        }
    }
}