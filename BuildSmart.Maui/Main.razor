<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Main).Assembly" AdditionalAssemblies="new[] { typeof(BuildSmart.SharedUI.Components.Layout.MainLayout).Assembly }">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(BuildSmart.SharedUI.Components.Layout.MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(BuildSmart.SharedUI.Components.Layout.MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>