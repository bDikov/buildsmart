<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:Class="BuildSmart.Maui.Views.JobWizardPage"
             x:DataType="vm:JobWizardViewModel"
             Title="Create Project">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StepToProgressConverter x:Key="StepToProgressConverter" />
            <converters:StepVisibleConverter x:Key="StepVisibleConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:BoolToColorConverter x:Key="ErrorColorConverter" TrueColor="Red" FalseColor="Black" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">
        <!-- Progress Bar & Title -->
        <VerticalStackLayout Grid.Row="0" Margin="10">
            <Label Text="{Binding CurrentStepTitle}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
            <ProgressBar Progress="{Binding CurrentStep, Converter={StaticResource StepToProgressConverter}}" Margin="0,5,0,0" />
        </VerticalStackLayout>

        <!-- Step 0: Basic Info -->
        <StackLayout Grid.Row="1" IsVisible="{Binding IsInfoStepVisible}" Padding="20">
            <Label Text="Project Title" FontSize="18" FontAttributes="Bold" TextColor="{Binding TitleHasError, Converter={StaticResource ErrorColorConverter}}"/>
            <Entry Text="{Binding ProjectTitle}" Placeholder="e.g., Kitchen Remodel" Margin="0,0,0,10"/>
            
            <Label Text="Location" FontSize="18" FontAttributes="Bold" TextColor="{Binding LocationHasError, Converter={StaticResource ErrorColorConverter}}"/>
            <Entry Text="{Binding ProjectLocation}" Placeholder="e.g., New York, NY" Margin="0,0,0,10"/>

            <Label Text="Description" FontSize="18" FontAttributes="Bold" TextColor="{Binding DescriptionHasError, Converter={StaticResource ErrorColorConverter}}"/>
            <Editor Text="{Binding ProjectDescription}" HeightRequest="100" Placeholder="Describe your project..." />

            <Button Text="Next: Select Category" 
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobWizardViewModel}}, Path=GoToNextStepCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" 
                    Margin="0,20,0,0" />
        </StackLayout>

        <!-- Step 1: Category Selection -->
        <ScrollView Grid.Row="1" 
                    IsVisible="{Binding IsCategoryStepVisible}">
            <VerticalStackLayout Padding="20" Spacing="10">
                <Label Text="Select Job Categories" FontSize="20" FontAttributes="Bold" TextColor="{Binding CategorySelectionHasError, Converter={StaticResource ErrorColorConverter}}"/>
                <CollectionView ItemsSource="{Binding SelectableCategories}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableCategoryViewModel">
                            <Frame Padding="10" CornerRadius="8" BorderColor="LightGray">
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                    <Label Text="{Binding Category.Name}" FontSize="16" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Next" Command="{Binding GoToNextStepCommand}" Margin="0,20,0,0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Dynamic Questions Step (Reused for all question steps) -->
        <ScrollView Grid.Row="1" IsVisible="{Binding IsQuestionStepVisible}">
            <VerticalStackLayout Padding="20" Spacing="15">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="15">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WizardQuestionViewModel">
                            <Frame Padding="15" CornerRadius="10" BorderColor="LightGray">
                                <VerticalStackLayout Spacing="5">
                                    <Label Text="{Binding CategoryName}" FontSize="10" TextColor="#1565C0" FontAttributes="Bold" TextTransform="Uppercase"/>
                                    <HorizontalStackLayout Spacing="2">
                                        <Label Text="{Binding Text}" FontSize="16" FontAttributes="Bold" TextColor="{Binding HasError, Converter={StaticResource ErrorColorConverter}}"/>
                                        <Label Text="*" FontSize="16" TextColor="Red" IsVisible="{Binding IsRequired}" />
                                    </HorizontalStackLayout>
                                    <Entry Text="{Binding Answer}" Placeholder="Type your answer here..." />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Next" Command="{Binding GoToNextStepCommand}" Margin="0,20,0,0" />
                <Button Text="Back" Command="{Binding GoToPreviousStepCommand}" BackgroundColor="Transparent" TextColor="Gray"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Review Step -->
        <StackLayout Grid.Row="1" IsVisible="{Binding IsReviewStepVisible}" Padding="20">
            <Label Text="Review &amp; Submit" FontSize="22" FontAttributes="Bold" />
            
            <Label Text="Title:" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Label Text="{Binding ProjectTitle}" />

            <Label Text="Selected Categories:" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding SelectableCategories}" >
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SelectableCategoryViewModel">
                        <!-- Only show selected items -->
                        <Label Text="{Binding Category.Name}" IsVisible="{Binding IsSelected}" Margin="10,0"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Post Project" 
                    Command="{Binding SubmitProjectCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Margin="0,30,0,0" BackgroundColor="{StaticResource Primary}" TextColor="White"/>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </StackLayout>
    </Grid>
</ContentPage>
