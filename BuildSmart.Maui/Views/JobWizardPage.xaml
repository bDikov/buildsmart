<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             x:Class="BuildSmart.Maui.Views.JobWizardPage"
             x:DataType="vm:JobWizardViewModel"
             Title="Create Project">

    <Grid RowDefinitions="Auto, *">
        <!-- Progress Bar -->
        <ProgressBar Progress="{Binding CurrentStep, Converter={StaticResource StepToProgressConverter}}" 
                     Grid.Row="0" Margin="10" />

        <!-- Step 0: Basic Info -->
        <StackLayout Grid.Row="1" IsVisible="{Binding CurrentStep, Converter={StaticResource StepVisibleConverter}, ConverterParameter=0}" Padding="20">
            <Label Text="Project Title" FontSize="18" FontAttributes="Bold" />
            <Entry Text="{Binding ProjectTitle}" Placeholder="e.g., Kitchen Remodel" Margin="0,0,0,10"/>
            
            <Label Text="Description" FontSize="18" FontAttributes="Bold" />
            <Editor Text="{Binding ProjectDescription}" HeightRequest="100" Placeholder="Describe your project..." />

            <Button Text="Next: Select Category" 
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:JobWizardViewModel}}, Path=GoToNextStepCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" 
                    Margin="0,20,0,0" />
        </StackLayout>

        <!-- Step 1: Category Selection -->
        <ScrollView Grid.Row="1" 
                    IsVisible="{Binding CurrentStep, Converter={StaticResource StepVisibleConverter}, ConverterParameter=1}">
            <VerticalStackLayout Padding="20" Spacing="10">
                <Label Text="Select Job Categories" FontSize="20" FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding SelectableCategories}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableCategoryViewModel">
                            <Frame Padding="10" CornerRadius="8" BorderColor="LightGray">
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                    <Label Text="{Binding Category.Name}" FontSize="16" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="Next" Command="{Binding GoToNextStepCommand}" Margin="0,20,0,0" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Step 2: Dynamic Wizard -->
        <ScrollView Grid.Row="1" IsVisible="{Binding CurrentStep, Converter={StaticResource StepVisibleConverter}, ConverterParameter=2}">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Label Text="Project Details" FontSize="20" HorizontalOptions="Center" FontAttributes="Bold"/>
                
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}" Spacing="15">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WizardQuestionViewModel">
                            <Frame Padding="15" CornerRadius="10" BorderColor="LightGray">
                                <VerticalStackLayout Spacing="5">
                                    <Label Text="{Binding CategoryName}" FontSize="10" TextColor="#1565C0" FontAttributes="Bold" TextTransform="Uppercase"/>
                                    <Label Text="{Binding Text}" FontSize="16" FontAttributes="Bold" />
                                    <Entry Text="{Binding Answer}" Placeholder="Type your answer here..." />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Review Project" Command="{Binding GoToNextStepCommand}" Margin="0,20,0,0" />
                <Button Text="Back" Command="{Binding GoToPreviousStepCommand}" BackgroundColor="Transparent" TextColor="Gray"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Step 3: Review -->
        <StackLayout Grid.Row="1" IsVisible="{Binding CurrentStep, Converter={StaticResource StepVisibleConverter}, ConverterParameter=3}" Padding="20">
            <Label Text="Review &amp; Submit" FontSize="22" FontAttributes="Bold" />
            
            <Label Text="Title:" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Label Text="{Binding ProjectTitle}" />

            <Label Text="Selected Categories:" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding SelectableCategories}" >
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SelectableCategoryViewModel">
                        <!-- Only show selected items -->
                        <Label Text="{Binding Category.Name}" IsVisible="{Binding IsSelected}" Margin="10,0"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Post Project" 
                    Command="{Binding SubmitProjectCommand}" 
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Margin="0,30,0,0" BackgroundColor="{StaticResource Primary}" TextColor="White"/>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </StackLayout>
    </Grid>
</ContentPage>
