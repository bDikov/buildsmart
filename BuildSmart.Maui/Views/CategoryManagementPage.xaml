<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:gql="clr-namespace:BuildSmart.Maui.GraphQL"
             x:DataType="vm:CategoryManagementViewModel"
             x:Class="BuildSmart.Maui.Views.CategoryManagementPage"
             Title="Category Management">
    <Grid RowDefinitions="Auto, Auto, *">
        
        <!-- Header / Global Config -->
        <Frame Grid.Row="0" Margin="10" Padding="15" BackgroundColor="#F5F5F5" BorderColor="LightGray">
            <VerticalStackLayout Spacing="5">
                <Label Text="Global Configuration" FontAttributes="Bold" FontSize="16" />
                <Label Text="Manage questions that appear on ALL job posts." FontSize="12" TextColor="Gray" />
                <Button Text="Edit Global Questions" 
                        Command="{Binding ManageGlobalQuestionsCommand}" 
                        Margin="0,10,0,0" 
                        BackgroundColor="#512BD4" TextColor="White" />
            </VerticalStackLayout>
        </Frame>

        <!-- Categories List Header -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Padding="15,0,15,5">
            <Label Text="Service Categories" FontAttributes="Bold" FontSize="18" VerticalOptions="End" />
            <Button Grid.Column="1" Text="+ New Category" Command="{Binding GoToNewCategoryDetailPageCommand}" HeightRequest="35" FontSize="12" />
        </Grid>

        <!-- Categories List -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Categories}" SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="gql:IGetAllServiceCategories_AllServiceCategories">
                    <Frame Margin="10" Padding="10" BorderColor="LightGray">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryManagementViewModel}}, Path=GoToDetailsCommand}"
                                                  CommandParameter="{Binding Id}"/>
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding Status, StringFormat='Status: {0}'}" FontSize="12" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" 
                                    Text="Toggle Status" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryManagementViewModel}}, Path=UpdateStatusCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
