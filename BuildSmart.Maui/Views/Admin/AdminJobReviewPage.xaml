<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels.Admin"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             x:Class="BuildSmart.Maui.Views.Admin.AdminJobReviewPage"
             x:DataType="vm:AdminJobReviewViewModel"
             Title="Job Scope Reviews">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadJobsCommand}">
        <Grid>
            <VerticalStackLayout IsVisible="{Binding IsEmpty}" VerticalOptions="Center" HorizontalOptions="Center">
                <Label Text="No jobs pending review." TextColor="Gray" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Jobs}" IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetJobsForReview_JobPostsForReview">
                        <Frame Margin="10" Padding="15" BorderColor="LightGray">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Project.Title}" FontSize="12" TextColor="Gray" />
                                <Label Text="{Binding Project.Homeowner.FirstName, StringFormat='Owner: {0}'}" FontSize="12" />
                                
                                <BoxView HeightRequest="1" Color="LightGray" Margin="0,5" />
                                
                                <Label Text="Edited Scope:" FontAttributes="Bold" FontSize="14" />
                                <Label Text="{Binding UserEditedScope}" FontSize="13" />

                                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,10,0,0">
                                    <Button Grid.Column="0" Text="Approve" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminJobReviewViewModel}}, Path=ApproveJobCommand}" CommandParameter="{Binding .}" BackgroundColor="Green" TextColor="White" />
                                    <Button Grid.Column="1" Text="Reject" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AdminJobReviewViewModel}}, Path=RejectJobCommand}" CommandParameter="{Binding .}" BackgroundColor="Red" TextColor="White" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </RefreshView>
</ContentPage>
