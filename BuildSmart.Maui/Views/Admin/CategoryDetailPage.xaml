<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels.Admin"
             x:DataType="vm:CategoryDetailViewModel"
             x:Class="BuildSmart.Maui.Views.Admin.CategoryDetailPage"
             Title="{Binding CategoryName, StringFormat='Edit: {0}'}">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="15">

            <Label Text="Category Name" FontSize="14" FontAttributes="Bold" />
            <Frame Padding="5" BorderColor="LightGray" CornerRadius="5">
                <Entry Text="{Binding CategoryName}" Placeholder="Enter category name" />
            </Frame>

            <Label Text="Category Description" FontSize="14" FontAttributes="Bold" />
            <Frame Padding="5" BorderColor="LightGray" CornerRadius="5">
                <Editor Text="{Binding CategoryDescription}" Placeholder="Enter category description" HeightRequest="100" />
            </Frame>

            <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsVisible="{Binding IsGlobalSwitchVisible}">
                <Label Grid.Column="0" Text="Is Global Category?" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding IsGlobal}" />
            </Grid>
            <Label Text="Global categories have questions that appear on ALL job posts." FontSize="11" TextColor="Gray" Margin="0,-5,0,0" />

            <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                <Label Grid.Column="0" Text="Status" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                <Picker Grid.Column="1" ItemsSource="{Binding AllStatuses}" SelectedItem="{Binding Status}" WidthRequest="150" />
            </Grid>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Questions" FontSize="16" FontAttributes="Bold" />
            
            <CollectionView ItemsSource="{Binding Questions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuestionViewModel">
                        <Frame Padding="10" Margin="0,5" BorderColor="Gainsboro" CornerRadius="8">
                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" RowSpacing="10" ColumnSpacing="10">
                                
                                <Label Grid.Row="0" Grid.Column="0" Text="Question Text" FontSize="12" />
                                <Entry Grid.Row="1" Grid.Column="0" Text="{Binding Text}" Placeholder="Enter question text" />

                                <Label Grid.Row="0" Grid.Column="1" Text="Type" FontSize="12" />
                                <Picker Grid.Row="1" Grid.Column="1" 
                                        ItemsSource="{Binding Source={x:Static vm:CategoryDetailViewModel.QuestionTypes}}"
                                        SelectedItem="{Binding Type}" />

                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" 
                                        Text="Remove" 
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryDetailViewModel}}, Path=RemoveQuestionCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ Add Question" Command="{Binding AddNewQuestionCommand}" HorizontalOptions="Start" Margin="0,10,0,0" />
            
            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />
            
            <Button Text="Save Category" Command="{Binding SaveCategoryCommand}" FontAttributes="Bold" BackgroundColor="{StaticResource Primary}" TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>