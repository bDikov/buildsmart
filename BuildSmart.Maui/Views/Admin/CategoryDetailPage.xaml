<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels.Admin"
             x:DataType="vm:CategoryDetailViewModel"
             x:Class="BuildSmart.Maui.Views.Admin.CategoryDetailPage"
             Title="{Binding CategoryName, StringFormat='Edit: {0}'}">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="15">

            <Label Text="Category Name" FontSize="14" FontAttributes="Bold" />
            <Frame Padding="5" BorderColor="LightGray" CornerRadius="5">
                <Entry Text="{Binding CategoryName}" Placeholder="Enter category name" />
            </Frame>

            <Label Text="Category Description" FontSize="14" FontAttributes="Bold" />
            <Frame Padding="5" BorderColor="LightGray" CornerRadius="5">
                <Editor Text="{Binding CategoryDescription}" Placeholder="Enter category description" HeightRequest="100" />
            </Frame>

            <Grid ColumnDefinitions="*, Auto" Margin="0,5" IsVisible="{Binding IsGlobalSwitchVisible}">
                <Label Grid.Column="0" Text="Is Global Category?" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding IsGlobal}" />
            </Grid>
            <Label Text="Global categories have questions that appear on ALL job posts." FontSize="11" TextColor="Gray" Margin="0,-5,0,0" />

            <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                <Label Grid.Column="0" Text="Status" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                <Picker Grid.Column="1" ItemsSource="{Binding AllStatuses}" SelectedItem="{Binding Status}" WidthRequest="150" />
            </Grid>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Questions" FontSize="16" FontAttributes="Bold" />
            
            <CollectionView ItemsSource="{Binding Questions}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuestionViewModel">
                        <Frame Padding="15" Margin="0,10" BorderColor="Gainsboro" CornerRadius="10" HasShadow="False" BackgroundColor="White">
                            <VerticalStackLayout Spacing="10">
                                
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Question Definition" FontAttributes="Bold" VerticalOptions="Center" />
                                    <Button Grid.Column="1" Text="Remove Question" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryDetailViewModel}}, Path=RemoveQuestionCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent" TextColor="Red" FontSize="12" />
                                </Grid>

                                <Label Text="Question Text" FontSize="12" TextColor="Gray" />
                                <Entry Text="{Binding Text}" Placeholder="e.g. Do you have parking?" />

                                <Grid ColumnDefinitions="*, *">
                                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                                        <Label Text="Type" FontSize="12" TextColor="Gray" />
                                        <Picker ItemsSource="{Binding AllQuestionTypes}"
                                                SelectedItem="{Binding Type}"
                                                Title="Select Type" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                                        <Label Text="Required?" FontSize="12" TextColor="Gray" />
                                        <CheckBox IsChecked="{Binding IsRequired}" HorizontalOptions="Center" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Choice Options Section -->
                                <VerticalStackLayout IsVisible="{Binding IsChoiceType}" Spacing="10" Padding="10" BackgroundColor="#F9F9F9">
                                    <Label Text="Choice Options" FontAttributes="Bold" FontSize="13" />
                                    
                                    <StackLayout BindableLayout.ItemsSource="{Binding Options}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:OptionViewModel">
                                                <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                                    <Entry Grid.Column="0" Text="{Binding Value}" Placeholder="Option Value" />
                                                    <Button Grid.Column="1" Text="X" 
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:QuestionViewModel}}, Path=RemoveOptionCommand}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="Transparent" TextColor="Gray" />
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <Button Text="+ Add Option" 
                                            Command="{Binding AddOptionCommand}"
                                            HorizontalOptions="Start"
                                            HeightRequest="35"
                                            FontSize="11" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="+ Add Question" Command="{Binding AddNewQuestionCommand}" HorizontalOptions="Start" Margin="0,10,0,0" />
            
            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />
            
            <Button Text="Save Category" Command="{Binding SaveCategoryCommand}" FontAttributes="Bold" BackgroundColor="{StaticResource Primary}" TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>