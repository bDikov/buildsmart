<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             x:Class="BuildSmart.Maui.Views.ProjectBidsPage"
             x:DataType="vm:ProjectBidsViewModel"
             x:Name="thisPage"
             Title="Review Bids">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Submitted Bids" FontSize="24" FontAttributes="Bold" TextColor="#1565C0"/>
            <Label Text="Review the offers received for your project." TextColor="Gray" FontSize="14" />

            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Job.Bids}">
                <BindableLayout.EmptyView>
                    <Label Text="No bids submitted yet." TextColor="Gray" FontSize="12" FontAttributes="Italic" Margin="10,0"/>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetProjectsForReview_ProjectsForReview_JobPosts_Bids">
                        <Frame BorderColor="#90CAF9" BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}" Padding="15" Margin="0,5" CornerRadius="8" HasShadow="False">
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Image Grid.Column="0" Source="{Binding TradesmanProfile.User.ProfilePictureUrl}" WidthRequest="40" HeightRequest="40" VerticalOptions="Center">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="20" RadiusY="20" Center="20,20"/>
                                        </Image.Clip>
                                    </Image>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                                        <Label Text="{Binding TradesmanProfile.User.FirstName, StringFormat='{0} (Tradesman)'}" FontAttributes="Bold" FontSize="14" />
                                        <Label Text="{Binding Amount.Total, StringFormat='Bid Amount: ${0:F2}'}" FontSize="14" FontAttributes="Bold" TextColor="#1976D2" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Text="View Offer" 
                                            Command="{Binding Source={x:Reference thisPage}, Path=BindingContext.ViewBidDetailsCommand}"
                                            CommandParameter="{Binding .}"
                                            x:DataType="{x:Null}"
                                            BackgroundColor="#4CAF50" TextColor="White" HeightRequest="35" Padding="10,0" CornerRadius="8" VerticalOptions="Center"/>
                                </Grid>
                                <Label Text="{Binding Comment}" FontSize="13" TextColor="Gray" Margin="0,5,0,0" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>