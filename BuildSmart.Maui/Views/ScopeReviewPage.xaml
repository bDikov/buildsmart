<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             x:Class="BuildSmart.Maui.Views.ScopeReviewPage"
             x:DataType="vm:ScopeReviewViewModel"
             x:Name="PageRoot"
             Title="Plan Tasks &amp; Milestones">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <Label Text="AI Generated Scope Reference" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Label Text="Use the AI suggestion below to break your project into specific tasks." FontSize="14" TextColor="Gray" />

            <Frame BorderColor="LightGray" Padding="15" HasShadow="False" BackgroundColor="{AppThemeBinding Light=#F9F9F9, Dark=#1A1A1A}">
                <Label Text="{Binding GeneratedScope}" TextColor="{AppThemeBinding Light=Black, Dark=White}" FontSize="12" />
            </Frame>

            <BoxView HeightRequest="1" Color="#E0E0E0" />

            <Label Text="Task Breakdown (Agile Bidding)" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Label Text="Tradesmen will bid on these specific tasks. Define what needs to be done and how you will accept the work." FontSize="12" TextColor="Gray" Margin="0,-10,0,10"/>

            <!-- List of Tasks -->
            <StackLayout BindableLayout.ItemsSource="{Binding Tasks}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:EditableTaskViewModel">
                        <Frame x:Name="TaskRoot" BorderColor="{StaticResource Primary}" Padding="15" Margin="0,5" HasShadow="False" CornerRadius="8">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding SequenceOrder, StringFormat='Task #{0}'}" FontAttributes="Bold" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EstimatedPrice, StringFormat='Cost: ${0:F2}'}" FontSize="12" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="2" Text="Remove Task" 
                                            x:DataType="{x:Null}"
                                            Command="{Binding BindingContext.RemoveTaskCommand, Source={x:Reference PageRoot}}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent" TextColor="Red" FontSize="12" Padding="0" HeightRequest="30" />
                                </Grid>

                                <Entry Text="{Binding Title}" Placeholder="Task Title (e.g., Demolition)" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <Editor Text="{Binding Description}" Placeholder="Optional detailed description..." AutoSize="TextChanges" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5" />
                                <Label Text="Acceptance Criteria (Definition of Done)" FontSize="12" FontAttributes="Bold" TextColor="Gray" />

                                <!-- List of Criteria within a Task -->
                                <StackLayout BindableLayout.ItemsSource="{Binding Criteria}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:EditableCriteriaViewModel">
                                            <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                                <Editor Grid.Column="0" Text="{Binding Description}" Placeholder="e.g. Area is swept clean" FontSize="12" TextColor="{AppThemeBinding Light=Black, Dark=White}" AutoSize="TextChanges" />
                                                <Button Grid.Column="1" Text="X" 
                                                        x:DataType="{x:Null}"
                                                        Command="{Binding BindingContext.RemoveCriteriaCommand, Source={x:Reference TaskRoot}}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="Transparent" TextColor="Gray" Padding="5,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>

                                <Button Text="+ Add Criteria" 
                                        Command="{Binding AddCriteriaCommand}" 
                                        HorizontalOptions="Start" 
                                        BackgroundColor="Transparent" 
                                        TextColor="{StaticResource Primary}" 
                                        FontSize="12" 
                                        HeightRequest="30" 
                                        Padding="0" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

            <Button Text="+ Add Another Task" Command="{Binding AddTaskCommand}" BackgroundColor="White" BorderColor="{StaticResource Primary}" BorderWidth="1" TextColor="{StaticResource Primary}" FontAttributes="Bold" />

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Generate Offer" 
                        Command="{Binding ApproveCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="10" 
                        FontAttributes="Bold" />
                
                <Button Grid.Column="1" Text="Back to Answers" 
                        Command="{Binding BackToEditAnswersCommand}"
                        BackgroundColor="Gray" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="10" />
            </Grid>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
