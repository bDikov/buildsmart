<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.SharedUI.ViewModels;assembly=BuildSmart.SharedUI"
             xmlns:graphql="clr-namespace:BuildSmart.SharedUI.GraphQL;assembly=BuildSmart.SharedUI"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:Class="BuildSmart.Maui.Views.ActiveJobsPage"
             x:DataType="vm:ActiveJobsViewModel"
             Title="Active Jobs &amp; Payouts">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" Color="{StaticResource Primary}"/>

        <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding InitializeAsyncCommand}" IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
            <CollectionView ItemsSource="{Binding ActiveBookings}" Margin="15">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10" Margin="0,50,0,0">
                        <Label Text="No Active Jobs" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" TextColor="Gray"/>
                        <Label Text="When a homeowner hires you, the jobs will appear here." FontSize="14" HorizontalOptions="Center" TextColor="Gray" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetMyActiveBookings_MyActiveBookings">
                        <Frame BorderColor="#4CAF50" BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}" CornerRadius="10" HasShadow="True" Margin="0,5,0,10" Padding="15">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveJobsViewModel}}, Path=ViewBookingDetailsCommand}" CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                            
                            <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="8">
                                <!-- Homeowner details -->
                                <HorizontalStackLayout Grid.Row="0" Spacing="10" VerticalOptions="Center">
                                    <Image Source="{Binding Homeowner.ProfilePictureUrl}" WidthRequest="40" HeightRequest="40">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="20" RadiusY="20" Center="20,20"/>
                                        </Image.Clip>
                                    </Image>
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding Homeowner.FirstName, StringFormat='Client: {0}'}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                                        <Label Text="{Binding CreatedAt, StringFormat='Hired On: {0:MMM dd, yyyy}'}" FontSize="12" TextColor="Gray" />
                                    </VerticalStackLayout>
                                    
                                    <Label Text="{Binding Status}" 
                                           BackgroundColor="#4CAF50" 
                                           TextColor="White" 
                                           Padding="8,4" 
                                           FontSize="11" 
                                           FontAttributes="Bold" 
                                           HorizontalOptions="EndAndExpand" 
                                           VerticalOptions="Start"/>
                                </HorizontalStackLayout>
                                
                                <BoxView Grid.Row="1" HeightRequest="1" Color="#C8E6C9" Margin="0,5"/>

                                <!-- Financial Brief -->
                                <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="Agreed Bid" FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding AgreedBidAmount.Total, StringFormat='${0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                    </VerticalStackLayout>
                                    
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                        <Label Text="Net Payout" FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding TotalEscrowAmount.Total, StringFormat='${0:F2}'}" FontSize="16" FontAttributes="Bold" TextColor="#2E7D32" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>