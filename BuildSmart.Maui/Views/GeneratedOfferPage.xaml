<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:models="clr-namespace:BuildSmart.Maui.GraphQL"
             x:Class="BuildSmart.Maui.Views.GeneratedOfferPage"
             x:DataType="vm:GeneratedOfferViewModel"
             Title="Generated Offer Overview">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <Label Text="Your Smart Offer" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
            <Label Text="Review the detailed breakdown of SKUs and estimated costs for each task." FontSize="14" TextColor="Gray" />

            <!-- Tasks and SKUs List -->
            <StackLayout BindableLayout.ItemsSource="{Binding Tasks}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:IJobTaskDetails">
                        <Frame BorderColor="#4CAF50" Padding="15" Margin="0,5" HasShadow="False" CornerRadius="8">
                            <VerticalStackLayout Spacing="10">
                                <!-- Task Header -->
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding EstimatedPrice, StringFormat='Total Task Cost: ${0:F2}'}" FontSize="14" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center" />
                                </Grid>
                                
                                <Label Text="{Binding Description}" FontSize="13" TextColor="Gray" Margin="0,0,0,10" IsVisible="{Binding Description, Converter={StaticResource StringIsNotNullOrEmptyConverter}}" />

                                <BoxView HeightRequest="1" Color="#EEEEEE" />
                                <Label Text="Billable SKUs &amp; Materials" FontSize="12" FontAttributes="Bold" TextColor="#1565C0" />

                                <!-- SKUs List -->
                                <StackLayout BindableLayout.ItemsSource="{Binding SkuItems}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ISkuItemDetails">
                                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Margin="0,5">
                                                <Label Grid.Column="0" Text="{Binding Quantity, StringFormat='{0}x'}" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                                                
                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                    <Label Text="{Binding ServiceSku.Name}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                                    <Label Text="{Binding ServiceSku.SkuCode}" FontSize="10" TextColor="Gray" />
                                                </VerticalStackLayout>
                                                
                                                <Label Grid.Column="2" Text="{Binding EstimatedPrice, StringFormat='${0:F2}'}" FontSize="12" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                                
                                <Label Text="No SKUs mapped for this task." FontSize="12" TextColor="Gray" IsVisible="{Binding SkuItems.Count, Converter={StaticResource InverseIntToBoolConverter}}" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

            <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />

            <Frame BorderColor="#4CAF50" BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}" Padding="15" CornerRadius="8" HasShadow="False">
                <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="Total Offer Value:" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" />
                    <Label Text="{Binding TotalEstimatedPrice, StringFormat='${0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Frame>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Submit to Admin" 
                        Command="{Binding SubmitToAdminCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="10" 
                        FontAttributes="Bold" />
                
                <Button Grid.Column="1" Text="Edit Tasks" 
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="Gray" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="10" />
            </Grid>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>