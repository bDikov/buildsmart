<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.SharedUI.ViewModels;assembly=BuildSmart.SharedUI"
             xmlns:graphql="clr-namespace:BuildSmart.SharedUI.GraphQL;assembly=BuildSmart.SharedUI"
             x:Class="BuildSmart.Maui.Views.PlaceBidPage"
             x:DataType="vm:PlaceBidViewModel"
             Title="Place a Bid">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Submit Your Proposal" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,10"/>

            <VerticalStackLayout Spacing="10">
                <Label Text="Itemized Bid Details" FontSize="16" FontAttributes="Bold" />
                <Label Text="Please provide a price for each task requested by the homeowner." FontSize="12" TextColor="Gray" />
                
                <StackLayout BindableLayout.ItemsSource="{Binding BidItems}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:BidItemViewModel">
                            <Frame x:Name="BidItemRoot" BorderColor="LightGray" CornerRadius="8" HasShadow="False" Padding="15" Margin="0,5">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{Binding JobTask.Title}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding JobTask.Description}" FontSize="14" TextColor="Gray" />
                                    
                                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5"/>
                                    <Label Text="Acceptance Criteria (Definition of Done):" FontSize="12" FontAttributes="Bold" TextColor="Gray"/>

                                    <StackLayout BindableLayout.ItemsSource="{Binding JobTask.AcceptanceCriteria}" Margin="10,0,0,10">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks_AcceptanceCriteria">
                                                <HorizontalStackLayout Spacing="8" Margin="0,2">
                                                    <Label Text="&#x2022;" FontSize="14" TextColor="#4CAF50" />
                                                    <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <StackLayout BindableLayout.ItemsSource="{Binding SubItems}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="vm:BidSubItemViewModel">
                                                <VerticalStackLayout Spacing="10" Margin="0,5">
                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,0,0,5">
                                                        <Label Grid.Column="0" Text="Line Item Breakdown" FontSize="12" FontAttributes="Bold" TextColor="Gray" VerticalOptions="Center"/>
                                                        <!-- Remove Button - Requires x:DataType={x:Null} and x:Reference to bind to parent Command -->
                                                        <Button Grid.Column="1" x:DataType="{x:Null}" Text="✖ Remove" FontSize="10" BackgroundColor="Transparent" TextColor="Red" Padding="0" HeightRequest="30"
                                                                Command="{Binding Source={x:Reference BidItemRoot}, Path=BindingContext.RemoveSubItemCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                    </Grid>
                                                    <VerticalStackLayout Spacing="10">
                                                        <Grid ColumnDefinitions="*,100" ColumnSpacing="10">
                                                            <!-- Duration -->
                                                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                                                <Label Text="Duration" FontSize="12" FontAttributes="Bold" TextColor="Gray" />
                                                                <Frame Padding="0" BorderColor="LightGray" CornerRadius="4" HasShadow="False">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <Entry Grid.Column="0" Text="{Binding Duration}" Keyboard="Numeric" Placeholder="1" FontSize="14" Margin="5,0"/>
                                                                        <Picker Grid.Column="1" ItemsSource="{Binding DurationUnits}" SelectedItem="{Binding DurationUnit}" FontSize="12" VerticalOptions="Center" Margin="5,0"/>
                                                                    </Grid>
                                                                </Frame>
                                                            </VerticalStackLayout>
                                                            
                                                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                                                <Label Text="Price (USD) *" FontSize="12" FontAttributes="Bold" TextColor="Gray" />
                                                                <Frame Padding="0" CornerRadius="4" HasShadow="False">
                                                                    <Frame.Triggers>
                                                                        <DataTrigger TargetType="Frame" Binding="{Binding HasError}" Value="True">
                                                                            <Setter Property="BorderColor" Value="Red"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger TargetType="Frame" Binding="{Binding HasError}" Value="False">
                                                                            <Setter Property="BorderColor" Value="LightGray"/>
                                                                        </DataTrigger>
                                                                    </Frame.Triggers>
                                                                    <Entry Text="{Binding Price}" Keyboard="Numeric" Placeholder="0.00" FontSize="14" Margin="5,0"/>
                                                                </Frame>
                                                            </VerticalStackLayout>
                                                        </Grid>
                                                        
                                                        <!-- Notes -->
                                                        <VerticalStackLayout Spacing="5">
                                                            <Label Text="Notes" FontSize="12" FontAttributes="Bold" TextColor="Gray" />
                                                            <Frame Padding="0" BorderColor="LightGray" CornerRadius="4" HasShadow="False">
                                                                <Editor Text="{Binding Comment}" Placeholder="Specifics..." HeightRequest="50" AutoSize="TextChanges" FontSize="14" Margin="5,0"/>
                                                            </Frame>
                                                        </VerticalStackLayout>
                                                    </VerticalStackLayout>
                                                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>

                                    <!-- Add button -->
                                    <Button Text="+ Add Another Line Item" 
                                            Command="{Binding AddSubItemCommand}"
                                            BackgroundColor="Transparent"
                                            TextColor="#2E7D32"
                                            FontAttributes="Bold"
                                            HorizontalOptions="Start"
                                            Padding="0"/>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </VerticalStackLayout>

            <!-- Total Amount -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F1F8E9, Dark=#1B5E20}" BorderColor="#C8E6C9" CornerRadius="8" HasShadow="False" Padding="15">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Total Bid Amount:" FontSize="18" FontAttributes="Bold" TextColor="#2E7D32" VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="{Binding TotalAmount, StringFormat='${0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32" VerticalOptions="Center"/>
                </Grid>
            </Frame>

            <VerticalStackLayout Spacing="5">
                <Label Text="Earliest Start Date" FontSize="14" FontAttributes="Bold" TextColor="Gray" />
                <Frame Padding="0" BorderColor="LightGray" CornerRadius="8" HasShadow="False">
                    <DatePicker Date="{Binding EarliestStartDate}" 
                                MinimumDate="{Binding EarliestStartDate}"
                                FontSize="16" 
                                Margin="10,0"/>
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Proposal / Comments" FontSize="14" FontAttributes="Bold" TextColor="Gray" />
                <Frame Padding="0" BorderColor="LightGray" CornerRadius="8" HasShadow="False">
                    <Editor Text="{Binding Comment}" 
                            Placeholder="Describe your approach, timeframe, or why they should choose you..." 
                            HeightRequest="150" 
                            FontSize="16" 
                            Margin="10,5"/>
                </Frame>
            </VerticalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="15" Margin="0,20,0,0">
                <Button Grid.Column="0" 
                        Text="Cancel" 
                        Command="{Binding CancelCommand}" 
                        BackgroundColor="Transparent" 
                        BorderColor="Gray" 
                        BorderWidth="1" 
                        TextColor="Gray" 
                        FontAttributes="Bold" 
                        HeightRequest="50" 
                        CornerRadius="8"/>
                
                <Button Grid.Column="1" 
                        Text="Submit Bid" 
                        Command="{Binding SubmitBidCommand}" 
                        BackgroundColor="#4CAF50" 
                        TextColor="White" 
                        FontAttributes="Bold" 
                        HeightRequest="50" 
                        CornerRadius="8"/>
            </Grid>
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="#4CAF50" Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>