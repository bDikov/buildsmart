<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             x:Class="BuildSmart.Maui.Views.TaskBreakdownPage"
             x:DataType="vm:TaskBreakdownViewModel"
             Title="{Binding Job.Title, StringFormat='Tasks: {0}'}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Button Text="Back to Project" Command="{Binding BackCommand}" HorizontalOptions="Start" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />

            <Label Text="Approved Task Breakdown" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32"/>
            <Label Text="The following tasks have been approved by the Admin and are open for tradesman bids." FontSize="14" TextColor="Gray" />

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" Color="#2E7D32" Margin="0,20"/>

            <StackLayout BindableLayout.ItemsSource="{Binding Tasks}" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                <BindableLayout.EmptyView>
                    <Label Text="No structured tasks provided." FontSize="14" TextColor="Gray" FontAttributes="Italic" Margin="0,20"/>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks">
                        <Border Stroke="#E0E0E0" BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}" Padding="15" Margin="0,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" LineBreakMode="WordWrap" Margin="0,5,0,0"/>
                                
                                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>
                                <Label Text="Acceptance Criteria:" FontSize="12" FontAttributes="Bold" TextColor="Gray"/>

                                <StackLayout BindableLayout.ItemsSource="{Binding AcceptanceCriteria}" Margin="10,5,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks_AcceptanceCriteria">
                                            <HorizontalStackLayout Spacing="8" Margin="0,2">
                                                <Label Text="тАв" FontSize="14" TextColor="#4CAF50" />
                                                <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                            </HorizontalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>