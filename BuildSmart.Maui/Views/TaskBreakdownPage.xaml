<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.SharedUI.ViewModels;assembly=BuildSmart.SharedUI"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             xmlns:graphql="clr-namespace:BuildSmart.SharedUI.GraphQL;assembly=BuildSmart.SharedUI"
             x:Class="BuildSmart.Maui.Views.TaskBreakdownPage"
             x:DataType="vm:TaskBreakdownViewModel"
             Title="{Binding Job.Title, StringFormat='Tasks: {0}'}"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            <Button Text="← Back to Project" Command="{Binding BackCommand}" HorizontalOptions="Start" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" FontAttributes="Bold" Padding="0" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Approved Task Breakdown" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#FFFFFF}"/>
                <Label Text="The following tasks have been approved by the Admin and are open for tradesman bids." FontSize="14" TextColor="{AppThemeBinding Light=#666666, Dark=#B0B0B0}" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" HorizontalOptions="Center" Color="#2E7D32" Margin="0,20"/>

            <StackLayout BindableLayout.ItemsSource="{Binding Tasks}" IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" Spacing="15">
                <BindableLayout.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,40">
                        <Label Text="No tasks available." FontSize="16" TextColor="{AppThemeBinding Light=#666666, Dark=#B0B0B0}" FontAttributes="Italic" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks">
                        <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}" />
                                <Label Text="{Binding Description}" FontSize="14" TextColor="{AppThemeBinding Light=#424242, Dark=#CCCCCC}" LineBreakMode="WordWrap" />
                                
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" Margin="0,10,0,10"/>
                                
                                <Label Text="Acceptance Criteria" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}" TextTransform="Uppercase" />

                                <StackLayout BindableLayout.ItemsSource="{Binding AcceptanceCriteria}" Spacing="6">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks_AcceptanceCriteria">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="✓" FontSize="14" TextColor="#4CAF50" FontAttributes="Bold" VerticalOptions="Center" />
                                                <Label Text="{Binding Description}" FontSize="14" TextColor="{AppThemeBinding Light=#212121, Dark=#E0E0E0}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>