<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             x:Class="BuildSmart.Maui.Views.ProjectDetailPage"
             x:DataType="vm:ProjectDetailViewModel"
             Title="Project Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="{Binding Project.Title}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
            <Label Text="{Binding Project.Status}" FontSize="14" TextColor="{StaticResource Primary}" />
            <Label Text="{Binding Project.Description}" TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Job Posts" FontSize="18" FontAttributes="Bold" />

            <StackLayout BindableLayout.ItemsSource="{Binding Project.JobPosts}">
                <BindableLayout.EmptyView>
                    <Label Text="No jobs found in this project." TextColor="Red" />
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="15" Margin="0,5" BorderColor="LightGray" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#333333}">
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                                <Label Text="{Binding ServiceCategory.Name}" TextColor="Gray" FontSize="12"/>
                                <Label Text="{Binding Status}" TextColor="Orange" FontSize="12"/>
                                <Label Text="{Binding Description}" TextColor="Gray" Margin="0,5,0,0"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
