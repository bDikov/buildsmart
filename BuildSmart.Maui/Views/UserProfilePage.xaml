<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:Class="BuildSmart.Maui.Views.UserProfilePage"
             x:DataType="vm:UserProfileViewModel"
             Title="Profile Settings">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringIsNotNullOrEmptyConverter x:Key="StringIsNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <!-- Profile Picture -->
            <Grid RowDefinitions="Auto, Auto" RowSpacing="10" HorizontalOptions="Center">
                <Frame Grid.Row="0" WidthRequest="120" HeightRequest="120" CornerRadius="60" IsClippedToBounds="True" Padding="0" BorderColor="LightGray">
                    <Image Source="{Binding ProfilePictureUrl, TargetNullValue='dotnet_bot.png'}" Aspect="AspectFill" />
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangePhotoCommand}" />
                    </Frame.GestureRecognizers>
                </Frame>
                
                <Button Grid.Row="1" 
                        Text="Change Photo" 
                        Command="{Binding ChangePhotoCommand}" 
                        FontSize="12" 
                        Padding="10,5" 
                        HeightRequest="35" 
                        BackgroundColor="Transparent" 
                        TextColor="{StaticResource Primary}" />
            </Grid>

            <Label Text="Personal Information" FontSize="18" FontAttributes="Bold" Margin="0,10,0,5" />

            <Label Text="First Name" FontSize="12" TextColor="Gray" />
            <Entry Text="{Binding FirstName}" Placeholder="First Name" />

            <Label Text="Last Name" FontSize="12" TextColor="Gray" />
            <Entry Text="{Binding LastName}" Placeholder="Last Name" />

            <Label Text="Email" FontSize="12" TextColor="Gray" />
            <Entry Text="{Binding Email}" IsReadOnly="True" TextColor="Gray" />

            <Label Text="Location" FontSize="12" TextColor="Gray" />
            <Entry Text="{Binding Location}" Placeholder="City, Country" />

            <Label Text="Bio" FontSize="12" TextColor="Gray" />
            <Editor Text="{Binding Bio}" Placeholder="Tell us about yourself..." HeightRequest="100" />

            <!-- Tradesman Multimedia Sections -->
            <VerticalStackLayout IsVisible="{Binding IsTradesman}" Spacing="20" Margin="0,20,0,0">
                <BoxView HeightRequest="1" Color="LightGray" />
                
                <!-- Video Intro -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Video Introduction" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Introduce yourself to homeowners with a short video." FontSize="12" TextColor="Gray" />
                    
                    <Frame BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2D2D2D}" Padding="15" HasShadow="False">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" 
                                   Text="{Binding VideoIntroductionUrl, TargetNullValue='No video uploaded yet'}" 
                                   VerticalOptions="Center" 
                                   FontSize="13" 
                                   LineBreakMode="HeadTruncation" />
                            <Button Grid.Column="1" 
                                    Text="Upload Video" 
                                    Command="{Binding ChangeVideoIntroCommand}"
                                    FontSize="11" HeightRequest="35" />
                        </Grid>
                    </Frame>
                </VerticalStackLayout>

                <!-- Portfolio Gallery -->
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Portfolio Gallery" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Add Work" Command="{Binding AddPortfolioItemCommand}" FontSize="11" HeightRequest="35" />
                    </Grid>
                    
                    <CollectionView ItemsSource="{Binding PortfolioEntries}" ItemsLayout="HorizontalList" HeightRequest="120">
                        <CollectionView.EmptyView>
                            <Label Text="Your portfolio is empty." TextColor="Gray" FontAttributes="Italic" HorizontalOptions="Center" VerticalOptions="Center" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="graphql:IGetCurrentUser_CurrentUser_TradesmanProfile_PortfolioEntries">
                                <Frame Margin="5,0" Padding="0" WidthRequest="100" HeightRequest="100" IsClippedToBounds="True">
                                    <Grid>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                        <Label Text="{Binding Title}" 
                                               VerticalOptions="End" 
                                               BackgroundColor="#CC000000" 
                                               TextColor="White" 
                                               FontSize="10" 
                                               Padding="5" 
                                               HorizontalTextAlignment="Center" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Certifications -->
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Certifications &amp; Credentials" FontSize="18" FontAttributes="Bold" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Add Cert" Command="{Binding AddCertificationCommand}" FontSize="11" HeightRequest="35" />
                    </Grid>

                    <StackLayout BindableLayout.ItemsSource="{Binding Certifications}">
                        <BindableLayout.EmptyView>
                            <Label Text="No certifications added yet." TextColor="Gray" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,10" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="graphql:IGetCurrentUser_CurrentUser_TradesmanProfile_Certifications">
                                <Border Stroke="#E0E0E0" Padding="10" Margin="0,2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="5" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" />
                                            <Label Text="{Binding IssuedAt, StringFormat='Issued: {0:d}'}" FontSize="11" TextColor="Gray" />
                                        </VerticalStackLayout>
                                        <Image Grid.Column="1" Source="dotnet_bot.png" WidthRequest="30" HeightRequest="30" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="Save Profile Info" 
                    Command="{Binding SaveProfileCommand}" 
                    BackgroundColor="{StaticResource Primary}" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    Margin="0,20,0,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
