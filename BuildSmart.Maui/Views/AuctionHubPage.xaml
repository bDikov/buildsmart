<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:DataType="vm:AuctionHubViewModel"
             x:Class="BuildSmart.Maui.Views.AuctionHubPage"
             x:Name="auctionPage"
             Title="Auction Hub">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:IsOwnQuestionConverter x:Key="IsOwnQuestionConverter" />
            <converters:EqualConverter x:Key="EqualConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

            <Label Text="{Binding Auction.Job.Title}" FontSize="24" FontAttributes="Bold" />
            <Label Text="{Binding Auction.Job.ServiceCategory.Name}" TextColor="{StaticResource Primary}" />
            
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#333333}" Padding="15">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Project Overview" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                    <Label Text="{Binding Auction.Job.Description}" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Submit Bid" BackgroundColor="{StaticResource Primary}" TextColor="White" />
            <Button Text="Ask Homeowner a Question" 
                    Command="{Binding AskQuestionCommand}"
                    BackgroundColor="White" TextColor="Gray" BorderColor="LightGray" BorderWidth="1" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Public Q&amp;A" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}"/>

            <StackLayout BindableLayout.ItemsSource="{Binding Auction.Questions}">
                <BindableLayout.EmptyView>
                    <Label Text="No questions asked yet." TextColor="Gray" FontAttributes="Italic" HorizontalOptions="Center" Margin="0,20"/>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="graphql:IGetAuctionById_AuctionById_Questions">
                        <Border Stroke="#E0E0E0" BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#2D2D2D}" Padding="12" Margin="0,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <HorizontalStackLayout Grid.Column="0" Spacing="5">
                                        <Label Text="{Binding TradesmanProfile.User.FirstName, StringFormat='Q: {0}'}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                        <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding IsEdited}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    
                                    <!-- Temporarily ALWAYS VISIBLE for testing - check ID in code -->
                                    <Button Grid.Column="1" Text="✎" 
                                            Clicked="OnEditQuestionClicked"
                                            CommandParameter="{Binding .}"
                                            FontSize="18" VerticalOptions="Center" HorizontalOptions="End"
                                            BackgroundColor="#EEEEEE" TextColor="{StaticResource Primary}" Padding="0" HeightRequest="30" WidthRequest="30" />
                                </Grid>
                                <Label Text="{Binding QuestionText}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                
                                <VerticalStackLayout IsVisible="{Binding IsAnswered}" Margin="0,5,0,0">
                                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,5" />
                                    <Label Text="Answer:" FontSize="11" FontAttributes="Bold" TextColor="Green" />
                                    <Label Text="{Binding AnswerText}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>
                                
                                <Label Text="Waiting for homeowner response..." 
                                       IsVisible="{Binding IsAnswered, Converter={StaticResource InverseBoolConverter}}"
                                       FontSize="11" TextColor="Gray" FontAttributes="Italic" Margin="0,5,0,0" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
