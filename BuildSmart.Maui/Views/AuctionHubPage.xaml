<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:Class="BuildSmart.Maui.Views.AuctionHubPage"
             x:DataType="vm:AuctionHubViewModel"
             x:Name="thisPage"
             Title="Auction Hub">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Button Text="Back to Listings" Command="{Binding BackCommand}" HorizontalOptions="Start" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />

            <!-- Job Overview -->
            <Frame Padding="15" BorderColor="LightGray">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding Auction.Job.Title}" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding Auction.Job.Location, StringFormat='Location: {0}'}" TextColor="Gray" />
                    <Label Text="{Binding Auction.Job.Status, StringFormat='Status: {0}'}" TextColor="Orange" FontAttributes="Bold" />
                    <Label Text="{Binding Auction.Job.Description}" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- Task Breakdown -->
            <VerticalStackLayout Spacing="10" Margin="0,10">
                <Label Text="Standardized Tasks" FontSize="18" FontAttributes="Bold" TextColor="#2E7D32"/>
                <Label Text="Your bid should cover the following required tasks and criteria:" FontSize="12" TextColor="Gray" />

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="#2E7D32" Margin="0,10"/>

                <StackLayout BindableLayout.ItemsSource="{Binding JobTasks}" IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <BindableLayout.EmptyView>
                        <Label Text="No standardized tasks provided." FontSize="14" TextColor="Gray" FontAttributes="Italic" Margin="0,10"/>
                    </BindableLayout.EmptyView>
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks">
                            <Border Stroke="#E0E0E0" BackgroundColor="{AppThemeBinding Light=White, Dark=#2D2D2D}" Padding="15" Margin="0,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout>
                                    <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                    <Label Text="{Binding Description}" FontSize="14" TextColor="Gray" LineBreakMode="WordWrap" Margin="0,5,0,0"/>
                                    
                                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,10"/>
                                    <Label Text="Acceptance Criteria:" FontSize="12" FontAttributes="Bold" TextColor="Gray"/>

                                    <StackLayout BindableLayout.ItemsSource="{Binding AcceptanceCriteria}" Margin="10,5,0,0">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="graphql:IGetJobTasks_AllJobPosts_JobTasks_AcceptanceCriteria">
                                                <HorizontalStackLayout Spacing="8" Margin="0,2">
                                                    <Label Text="&#x2022;" FontSize="14" TextColor="#4CAF50" />
                                                    <Label Text="{Binding Description}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </VerticalStackLayout>

            <!-- My Submitted Bid Section -->
            <VerticalStackLayout Spacing="10" IsVisible="{Binding HasSubmittedBid}">
                <Label Text="Your Submitted Bid" FontSize="18" FontAttributes="Bold" TextColor="#1976D2" />
                <Frame BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}" BorderColor="#90CAF9" CornerRadius="8" HasShadow="False" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Total Amount Submitted:" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding MyBid.Amount.Total, StringFormat='${0:F2}'}" FontSize="18" FontAttributes="Bold" TextColor="#1976D2" VerticalOptions="Center"/>
                        </Grid>
                        <Label Text="Status:" FontSize="14" FontAttributes="Bold" Margin="0,5,0,0"/>
                        <Label Text="Under Review" TextColor="Orange" FontAttributes="Italic" IsVisible="{Binding MyBid.IsAccepted, Converter={StaticResource InverseBoolConverter}}" />
                        <Label Text="Accepted!" TextColor="Green" FontAttributes="Bold" IsVisible="{Binding MyBid.IsAccepted}" />

                        <Label Text="Your Proposal:" FontSize="14" FontAttributes="Bold" Margin="0,5,0,0"/>
                        <Label Text="{Binding MyBid.Comment}" FontSize="14" TextColor="Gray" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <Button Text="Place Bid"
                    Command="{Binding GoToPlaceBidCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="8"
                    Margin="0,5">
                <Button.Triggers>
                    <MultiTrigger TargetType="Button">
                        <MultiTrigger.Conditions>
                            <BindingCondition Binding="{Binding HasSubmittedBid}" Value="False" />
                            <BindingCondition Binding="{Binding IsBusy}" Value="False" />
                        </MultiTrigger.Conditions>
                        <Setter Property="IsVisible" Value="True" />
                    </MultiTrigger>
                    <MultiTrigger TargetType="Button">
                        <MultiTrigger.Conditions>
                            <BindingCondition Binding="{Binding HasSubmittedBid}" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="IsVisible" Value="False" />
                    </MultiTrigger>
                    <MultiTrigger TargetType="Button">
                        <MultiTrigger.Conditions>
                            <BindingCondition Binding="{Binding IsBusy}" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="IsVisible" Value="False" />
                    </MultiTrigger>
                </Button.Triggers>
            </Button>
            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Public Q&A Section -->
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="Public Q&amp;A" FontSize="18" FontAttributes="Bold" />
                <Button Text="Ask a Question" 
                        Command="{Binding AskQuestionCommand}"
                        HeightRequest="30" FontSize="10" Padding="10,0" 
                        BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="15"/>
            </HorizontalStackLayout>

            <StackLayout BindableLayout.ItemsSource="{Binding Questions}">
                <BindableLayout.EmptyView>
                    <Label Text="No public questions yet." TextColor="Gray" FontSize="12" FontAttributes="Italic" Margin="10,0"/>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuestionViewModel">
                        <Border Stroke="#C8E6C9" BackgroundColor="{AppThemeBinding Light=#F1F8E9, Dark=#1B5E20}" Padding="12" Margin="0,2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="5">
                                    <Button Text="&#x270E;" 
                                            Clicked="OnEditQuestionClicked"
                                            CommandParameter="{Binding Question}"
                                            IsVisible="{Binding Question.IsEditable}"
                                            FontSize="14" BackgroundColor="Transparent" TextColor="Gray" Padding="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center" />
                                    <Label Text="{Binding Question.TradesmanProfile.User.FirstName, StringFormat='Q from {0}:'}" FontSize="11" FontAttributes="Bold" TextColor="#388E3C" VerticalOptions="Center" />
                                    <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding Question.IsEdited}" VerticalOptions="Center" />
                                    <Label Text="{Binding Question.CreatedAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding Question.QuestionText}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" LineBreakMode="WordWrap" />
                                </HorizontalStackLayout>

                                <BoxView HeightRequest="1" Color="#C8E6C9" Margin="0,5" IsVisible="{Binding Question.IsAnswered}" />
                                
                                <!-- Owner Answer -->
                                <VerticalStackLayout IsVisible="{Binding Question.IsAnswered}">
                                    <HorizontalStackLayout Spacing="5">
                                        <Button Text="&#x270E;" 
                                                Clicked="OnEditAnswerClicked"
                                                CommandParameter="{Binding Question}"
                                                IsVisible="{Binding Question.IsAnswerEditable}"
                                                FontSize="14" BackgroundColor="Transparent" TextColor="#1B5E20" Padding="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center" />
                                        <Label Text="Homeowner's Answer:" FontSize="11" FontAttributes="Bold" TextColor="#1B5E20" VerticalOptions="Center" />
                                        <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding Question.IsAnswerEdited}" VerticalOptions="Center" />
                                        <Label Text="{Binding Question.AnsweredAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Question.AnswerText}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Spacing="15" Margin="0,5,0,0">
                                    <Label Text="Reply" 
                                           TextColor="Gray" 
                                           FontAttributes="Bold" 
                                           FontSize="12">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Tapped="OnReplyQuestionClicked"
                                                CommandParameter="{Binding Question}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <!-- Lazy Loading Trigger -->
                                    <Label Text="{Binding ButtonText}" 
                                           IsVisible="{Binding HasAnyReplies}"
                                           TextColor="{StaticResource Primary}" 
                                           FontAttributes="Bold" 
                                           FontSize="12">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding ToggleConversationCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Threaded Replies (Lazy Loaded) -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Replies}" 
                                                     IsVisible="{Binding IsExpanded}"
                                                     Margin="5,10,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="graphql:IQuestionReplyDetails">
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="0,5">
                                                <BoxView Grid.Column="0" 
                                                         WidthRequest="2" 
                                                         Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" 
                                                         Margin="10,0,15,0" 
                                                         VerticalOptions="FillAndExpand" />

                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Border Stroke="Transparent" BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#3A3B3C}" Padding="12,8" HorizontalOptions="Start">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="18" />
                                                        </Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="2">
                                                            <HorizontalStackLayout Spacing="5">
                                                                <Button Text="&#x270E;" 
                                                                        Clicked="OnEditNestedQuestionClicked"
                                                                        CommandParameter="{Binding .}"
                                                                        IsVisible="{Binding IsEditable}"
                                                                        FontSize="14" BackgroundColor="Transparent" TextColor="Gray" Padding="0" HeightRequest="30" WidthRequest="30" VerticalOptions="Center" />

                                                                <Label Text="{Binding Author.FirstName}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}" VerticalOptions="Center" />

                                                                <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding IsEdited}" VerticalOptions="Center" />
                                                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                            <Label Text="{Binding QuestionText}" FontSize="13" TextColor="{AppThemeBinding Light=#1C1E21, Dark=#E4E6EB}" />
                                                        </VerticalStackLayout>
                                                    </Border>
                                                    
                                                    <Label Text="Reply" 
                                                           TextColor="Gray" 
                                                           FontSize="11" 
                                                           FontAttributes="Bold" 
                                                           Margin="12,2,0,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer 
                                                                Tapped="OnReplyQuestionClicked"
                                                                CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
