<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuildSmart.Maui.ViewModels"
             xmlns:graphql="clr-namespace:BuildSmart.Maui.GraphQL"
             xmlns:converters="clr-namespace:BuildSmart.Maui.Converters"
             x:Class="BuildSmart.Maui.Views.AuctionHubPage"
             x:DataType="vm:AuctionHubViewModel"
             Title="Auction Hub">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:IsNullConverter x:Key="IsNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Button Text="Back to Listings" Command="{Binding BackCommand}" HorizontalOptions="Start" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />

            <!-- Job Overview -->
            <Frame Padding="15" BorderColor="LightGray">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding Auction.Job.Title}" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding Auction.Job.Location, StringFormat='Location: {0}'}" TextColor="Gray" />
                    <Label Text="{Binding Auction.Job.Status, StringFormat='Status: {0}'}" TextColor="Orange" FontAttributes="Bold" />
                    <Label Text="{Binding Auction.Job.Description}" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Public Q&A Section -->
            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="Public Q&amp;A" FontSize="18" FontAttributes="Bold" />
                <Button Text="Ask a Question" 
                        Command="{Binding AskQuestionCommand}"
                        HeightRequest="30" FontSize="10" Padding="10,0" 
                        BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="15"/>
            </HorizontalStackLayout>

            <StackLayout BindableLayout.ItemsSource="{Binding Questions}">
                <BindableLayout.EmptyView>
                    <Label Text="No public questions yet." TextColor="Gray" FontSize="12" FontAttributes="Italic" Margin="10,0"/>
                </BindableLayout.EmptyView>
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:QuestionViewModel">
                        <Border Stroke="#C8E6C9" BackgroundColor="{AppThemeBinding Light=#F1F8E9, Dark=#1B5E20}" Padding="12" Margin="0,2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="4">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding Question.TradesmanProfile.User.FirstName, StringFormat='Q from {0}:'}" FontSize="11" FontAttributes="Bold" TextColor="#388E3C" />
                                    <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding Question.IsEdited}" VerticalOptions="Center" />
                                    <Label Text="{Binding Question.CreatedAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="{Binding Question.QuestionText}" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" LineBreakMode="WordWrap" />
                                    <Button Text="Edit" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=EditQuestionCommand}"
                                            CommandParameter="{Binding Question}"
                                            IsVisible="{Binding Question.IsEditable}"
                                            FontSize="10" BackgroundColor="Transparent" TextColor="Gray" Padding="0" HeightRequest="20" />
                                </HorizontalStackLayout>

                                <BoxView HeightRequest="1" Color="#C8E6C9" Margin="0,5" IsVisible="{Binding Question.IsAnswered}" />
                                
                                <!-- Owner Answer -->
                                <VerticalStackLayout IsVisible="{Binding Question.IsAnswered}">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="Homeowner's Answer:" FontSize="11" FontAttributes="Bold" TextColor="#1B5E20" />
                                        <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding Question.IsAnswerEdited}" VerticalOptions="Center" />
                                        <Label Text="{Binding Question.AnsweredAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                        
                                        <Button Text="Edit" 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=EditAnswerCommand}"
                                                CommandParameter="{Binding Question}"
                                                IsVisible="{Binding Question.IsAnswerEditable}"
                                                FontSize="10" BackgroundColor="Transparent" TextColor="#1B5E20" Padding="0" HeightRequest="20" />
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Question.AnswerText}" FontSize="13" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                </VerticalStackLayout>

                                <HorizontalStackLayout Spacing="15" Margin="0,5,0,0">
                                    <Label Text="Reply" 
                                           TextColor="Gray" 
                                           FontAttributes="Bold" 
                                           FontSize="12">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=ReplyToQuestionCommand}"
                                                CommandParameter="{Binding Question}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <!-- Lazy Loading Trigger -->
                                    <Label Text="{Binding ButtonText}" 
                                           IsVisible="{Binding Question.ReplyCount, Converter={StaticResource InverseBoolConverter}, ConverterParameter=0}"
                                           TextColor="{StaticResource Primary}" 
                                           FontAttributes="Bold" 
                                           FontSize="12">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=ToggleConversationCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Threaded Replies (Lazy Loaded) -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Replies}" 
                                                     IsVisible="{Binding IsExpanded}"
                                                     Margin="5,10,0,0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="graphql:IQuestionReplyDetails">
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="0,5">
                                                <BoxView Grid.Column="0" 
                                                         WidthRequest="2" 
                                                         Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" 
                                                         Margin="10,0,15,0" 
                                                         VerticalOptions="FillAndExpand" />

                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Border Stroke="Transparent" BackgroundColor="{AppThemeBinding Light=#F0F2F5, Dark=#3A3B3C}" Padding="12,8" HorizontalOptions="Start">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="18" />
                                                        </Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="2">
                                                            <HorizontalStackLayout Spacing="5">
                                                                <Label Text="{Binding Author.FirstName}" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                                                                
                                                                <Button Text="Edit" 
                                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=EditNestedQuestionCommand}"
                                                                        CommandParameter="{Binding .}"
                                                                        IsVisible="{Binding IsEditable}"
                                                                        FontSize="10" BackgroundColor="Transparent" TextColor="Gray" Padding="0" HeightRequest="20" />
                                                                
                                                                <Label Text="(EDITED)" FontSize="9" TextColor="Gray" IsVisible="{Binding IsEdited}" VerticalOptions="Center" />
                                                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}" FontSize="10" TextColor="Gray" VerticalOptions="Center" />
                                                            </HorizontalStackLayout>
                                                            <Label Text="{Binding QuestionText}" FontSize="13" TextColor="{AppThemeBinding Light=#1C1E21, Dark=#E4E6EB}" />
                                                        </VerticalStackLayout>
                                                    </Border>
                                                    
                                                    <Label Text="Reply" 
                                                           TextColor="Gray" 
                                                           FontSize="11" 
                                                           FontAttributes="Bold" 
                                                           Margin="12,2,0,0">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer 
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=ReplyToNestedQuestionCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                                
                                <!-- Load More within expanded thread -->
                                <Label Text="Show More Replies..." 
                                       IsVisible="{Binding HasMoreReplies}"
                                       TextColor="{StaticResource Primary}"
                                       FontAttributes="Bold"
                                       FontSize="11"
                                       Margin="40,5,0,0"
                                       HorizontalOptions="Start">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AuctionHubViewModel}}, Path=LoadMoreRepliesCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
