<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BuildSmart.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:BuildSmart.Maui.Views"
    FlyoutBehavior="Disabled"
    Shell.TabBarIsVisible="False">

    <TabBar>
        <Tab Route="LoginTab">
            <ShellContent
                Title="Login"
                ContentTemplate="{DataTemplate views:LoginPage}"
                Route="LoginPage" />
        </Tab>

        <Tab Route="MainTab">
            <ShellContent
                Title="Main"
                ContentTemplate="{DataTemplate views:BlazorHostPage}"
                Route="BlazorHostPage" />
        </Tab>
    </TabBar>

</Shell>