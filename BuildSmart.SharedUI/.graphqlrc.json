
{
  "schema": "GraphQL/schema.graphql",
  "documents": "**/*.graphql",
  "extensions": {
    "strawberryShake": {
      "name": "BuildSmartApiClient",
      "namespace": "BuildSmart.SharedUI.GraphQL",
      "url": "http://localhost:5086/graphql/",
      "typeMappings": [
        {
          "name": "UUID",
          "runtimeType": "System.Guid"
        },
        {
          "name": "ID",
          "runtimeType": "System.Guid"
        },
        {
          "name": "Decimal",
          "runtimeType": "System.Decimal"
        },
        {
          "name": "DateTime",
          "runtimeType": "System.DateTimeOffset"
        }
      ]
    }
  }
}

