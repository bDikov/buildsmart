@using BuildSmart.SharedUI.GraphQL
@inject NavigationManager NavManager
@inject IBuildSmartApiClient ApiClient
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<BuildSmart.SharedUI.Resources.AppResources> Loc

<div class="menu-container">
    <div class="menu-header mb-3 px-3">
        <h4 class="fw-bold" style="color: var(--text-primary);">@Loc["Settings_Title"]</h4>
    </div>

    <!-- Language Selector -->
    <div class="menu-item-row">
        <div class="d-flex align-items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            </svg>
            <span class="fw-bold" style="color: var(--text-primary);">@Loc["Settings_Language"]</span>
        </div>
        <select class="bs-input form-select form-select-sm w-auto" style="border-radius: 8px; font-weight: bold; background-color: var(--bg-card-alt);" value="@_currentLang" @onchange="ChangeLanguage">
            <option value="en">English</option>
            <option value="bg">Български</option>
        </select>
    </div>

    <!-- Theme Selector Placeholder -->
    <div class="menu-item-row">
        <div class="d-flex align-items-center gap-3">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <span class="fw-bold" style="color: var(--text-primary);">@Loc["Settings_Theme"]</span>
        </div>
        <select class="bs-input form-select form-select-sm w-auto" style="border-radius: 8px; font-weight: bold; background-color: var(--bg-card-alt);">
            <option value="system">@Loc["Settings_SystemDefault"]</option>
            <option value="light">@Loc["Settings_Light"]</option>
            <option value="dark">@Loc["Settings_Dark"]</option>
        </select>
    </div>

    <hr style="border-color: var(--border-color); margin: 15px 0;" />

    <a href="/faq" class="menu-item-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
        <span>@Loc["Settings_FAQ"]</span>
    </a>
    <a href="/terms" class="menu-item-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        <span>@Loc["Settings_Terms"]</span>
    </a>
</div>

<style>
    .menu-container {
        background-color: var(--bg-card);
        border-radius: 20px;
        width: 350px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        box-sizing: border-box;
        font-family: var(--font-primary);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .menu-item-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 16px;
        border-radius: 12px;
        background-color: var(--bg-page);
    }

    .menu-item-link {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 16px;
        border-radius: 12px;
        color: var(--text-primary);
        text-decoration: none;
        transition: background-color 0.2s;
        font-weight: 500;
    }

    .menu-item-link:hover {
        background-color: var(--bg-card-alt);
        color: var(--color-primary);
    }

    .menu-item-link svg {
        color: var(--text-muted);
        transition: color 0.2s;
    }

    .menu-item-link:hover svg {
        color: var(--color-primary);
    }
</style>

@code {
    private string _currentLang = "en";

    protected override void OnInitialized()
    {
        _currentLang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    }

    private async Task ChangeLanguage(ChangeEventArgs e)
    {
        var lang = e.Value?.ToString() ?? "en";
        
        try
        {
            await ApiClient.UpdateUserLanguage.ExecuteAsync(lang);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Settings] Failed to update language on server: {ex.Message}");
        }

        var culture = new System.Globalization.CultureInfo(lang);
        System.Globalization.CultureInfo.DefaultThreadCurrentCulture = culture;
        System.Globalization.CultureInfo.DefaultThreadCurrentUICulture = culture;
        NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
    }
}
