@using BuildSmart.SharedUI.GraphQL

<div class="overview-card bs-card mb-4">
    <div class="d-flex justify-content-between align-items-start mb-2">
        <h3 class="section-title mb-0" style="color: var(--color-primary);">@Loc["ProjectDetail_Overview"]</h3>
        
        @if (IsMasterOfferReady)
        {
            <button class="bs-btn-primary" @onclick="async () => await OnDownloadMasterOffer.InvokeAsync()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                </svg>
                @Loc["ProjectDetail_DownloadOffer", "Download Official Offer"]
            </button>
        }
    </div>
    <p class="project-description mt-2">
        @(string.IsNullOrEmpty(Project?.GeneralSummary) ? Project?.Description : Project?.GeneralSummary)
    </p>
    
    @if (Project?.Status == ProjectStatus.Draft)
    {
        <div class="mt-3">
            <button class="bs-btn-primary w-100" @onclick="async () => await OnContinueDraft.InvokeAsync()">
                @Loc["ProjectDetail_ContinueDraft"]
            </button>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public IProjectDetails Project { get; set; } = default!;

    [Parameter]
    public bool IsMasterOfferReady { get; set; }

    [Parameter]
    public EventCallback OnDownloadMasterOffer { get; set; }

    [Parameter]
    public EventCallback OnContinueDraft { get; set; }
}
