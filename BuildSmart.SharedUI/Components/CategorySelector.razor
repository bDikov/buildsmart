@using BuildSmart.SharedUI.ViewModels

<div class="bs-card category-card">
    <h3 class="category-header @(HasError ? "text-danger" : "")">@Loc["JobWizard_CategoryLabel"]</h3>
    
    <div class="category-list mb-4">
        @if (Categories != null)
        {
            @foreach (var cat in Categories)
            {
                <label class="category-item">
                    <input class="category-checkbox" type="checkbox" @bind="cat.IsSelected">
                    <span class="category-label">
                        @cat.Category?.Name
                    </span>
                </label>
            }
        }
    </div>

    <button class="bs-btn-primary w-100 fw-bold" disabled="@IsBusy" @onclick="OnNextClicked">
        @NextButtonText
    </button>
</div>

<style>
    .category-card {
        padding: 30px;
        font-family: var(--font-primary);
    }
    
    .category-header {
        font-family: var(--font-heading);
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 25px;
        color: var(--text-primary);
    }
    
    .category-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }
    
    .category-item {
        display: flex;
        align-items: center;
        gap: 15px;
        cursor: pointer;
    }
    
    .category-checkbox {
        appearance: none;
        -webkit-appearance: none;
        width: 19px;
        height: 19px;
        background-color: var(--bg-card-alt);
        border: 2px solid var(--border-color);
        border-radius: 3px;
        cursor: pointer;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin: 0;
        transition: border-color 0.2s ease;
    }

    .category-checkbox:checked {
        border-color: var(--color-primary);
    }
    
    .category-checkbox:checked::after {
        content: '';
        width: 11px;
        height: 11px;
        background-color: var(--color-primary);
        border-radius: 2px;
    }
    
    .category-label {
        font-family: var(--font-primary);
        font-size: 16px;
        font-weight: 400;
        margin: 0;
        color: var(--text-primary);
    }
</style>

@code {
    [Parameter, EditorRequired]
    public IEnumerable<SelectableCategoryViewModel> Categories { get; set; } = default!;

    [Parameter]
    public bool HasError { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public string NextButtonText { get; set; } = "Next";

    [Parameter]
    public EventCallback OnNextClicked { get; set; }
}
