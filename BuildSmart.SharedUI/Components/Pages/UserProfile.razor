@page "/user-profile"
@using BuildSmart.SharedUI.ViewModels
@using BuildSmart.SharedUI.Components
@inject UserProfileViewModel ViewModel

<div class="profile-page-container">
	<div class="header-section">
		<h2 class="page-title">Profile Settings</h2>
	</div>

	@if (ViewModel.IsBusy && string.IsNullOrEmpty(ViewModel.FirstName))
	{
		<div class="loading-state">
			<p>Loading profile...</p>
		</div>
	}
	else
	{
		<div class="profile-layout">
			<!-- The beautiful Profile Card we generated from Figma -->
			<div class="profile-sidebar">
			    <ProfileCard ViewModel="ViewModel" OnEditProfileClicked="OpenEditModal" OnMoreClicked="OpenSettingsModal" />
			</div>		</div>

		<!-- Edit Details Modal -->
		@if (_showEditModal)
		{
			<div class="modal-overlay" @onclick="CloseEditModal">
				<div class="modal-content bs-card" @onclick:stopPropagation="true">
					<div class="modal-header">
						<h3>Edit Details</h3>
						<button class="close-btn" @onclick="CloseEditModal">
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M18 6L6 18M6 6l12 12" />
							</svg>
						</button>
					</div>

					<div class="modal-body">
						<div class="form-group">
							<label>First Name</label>
							<input class="bs-input" @bind="ViewModel.FirstName" />
						</div>
						<div class="form-group">
							<label>Last Name</label>
							<input class="bs-input" @bind="ViewModel.LastName" />
						</div>
						<div class="form-group">
							<label>Location</label>
							<input class="bs-input" @bind="ViewModel.Location" />
						</div>
						<div class="form-group" style="margin-bottom: 10px;">
							<label>Bio</label>
							<textarea class="bs-input" rows="4" @bind="ViewModel.Bio"></textarea>
						</div>

						<div class="modal-actions">
							<button class="bs-btn-primary w-100" @onclick="SaveAndCloseModal">
								Save Changes
							</button>
						</div>
					</div>
				</div>
			</div>
		}

		<!-- Tradesman Settings Modal -->
		@if (_showSettingsModal)
		{
			<div class="modal-overlay" @onclick="CloseSettingsModal">
				<div class="modal-content settings-modal-content" @onclick:stopPropagation="true">
					<ProfileSettingsMenu />
				</div>
			</div>
		}
	}
</div>

<style>
	.profile-page-container {
		padding: 40px 20px;
		font-family: var(--font-primary);
		max-width: 1000px;
		margin: 0 auto;
	}

	.header-section {
		margin-bottom: 40px;
		text-align: center;
	}

	.page-title {
		font-family: var(--font-heading);
		color: var(--text-primary);
		font-size: 32px;
		margin: 0;
	}

	.loading-state {
		text-align: center;
		padding: 50px 20px;
	}

	.profile-layout {
		display: flex;
		justify-content: center;
		gap: 40px;
		align-items: start;
		flex-wrap: wrap;
	}

	/* Modal Styles */
	.modal-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		background-color: rgba(0, 0, 0, 0.6);
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1000;
		backdrop-filter: blur(4px);
	}

	.modal-content {
		width: 100%;
		max-width: 480px;
		max-height: 90vh; /* Keeps the modal within the viewport */
		overflow-y: auto; /* Adds scrolling for small screens */
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 20px;
		box-sizing: border-box;
	}

	.settings-modal-content {
		background: transparent;
		box-shadow: none;
		align-items: center;
		padding: 0;
		max-width: 380px;
	}

	.modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 10px;
	}

		.modal-header h3 {
			margin: 0;
			font-size: 24px;
			color: var(--text-primary);
		}

	.close-btn {
		background: transparent;
		border: none;
		color: var(--text-secondary);
		cursor: pointer;
		padding: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s ease;
	}

		.close-btn:hover {
			color: var(--color-primary);
		}

	.modal-body {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

		.form-group label {
			color: var(--text-secondary);
			font-weight: 500;
			font-size: 14px;
		}

	.modal-actions {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin-top: 15px;
	}

	.w-100 {
		width: 100%;
	}
</style>

@code {
	private bool _showEditModal = false;
	private bool _showSettingsModal = false;

	protected override async Task OnInitializedAsync()
	{
		if (string.IsNullOrEmpty(ViewModel.FirstName))
		{
			// Execute the load command if data isn't present
			await ViewModel.LoadProfileCommand.ExecuteAsync(null);
		}
	}

	private void OpenEditModal()
	{
		_showEditModal = true;
	}

	private void CloseEditModal()
	{
		_showEditModal = false;
	}

	private void OpenSettingsModal()
	{
		_showSettingsModal = true;
	}

	private void CloseSettingsModal()
	{
		_showSettingsModal = false;
	}

	private async Task SaveAndCloseModal()
	{
		await ViewModel.SaveProfileCommand.ExecuteAsync(null);
		_showEditModal = false;
	}
}
