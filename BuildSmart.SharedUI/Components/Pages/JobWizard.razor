@page "/job-wizard"
@using BuildSmart.SharedUI.ViewModels
@using System.ComponentModel
@layout BuildSmart.SharedUI.Components.Layout.MainLayout
@implements IDisposable
@inject JobWizardViewModel ViewModel

<ErrorBoundary>
    <ChildContent>
        @if (ViewModel == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="container py-4">
                <!-- Progress Bar & Title -->
                <BuildSmart.SharedUI.Components.ProgressCard 
                    Title="Your progress" 
                    ProgressPercentage="@ViewModel.ProgressPercentage" 
                    StepText="@ViewModel.StepText" 
                    SubtitleText="@GetSubtitleText()" />

                <!-- Step 0: Basic Info -->
                @if (ViewModel.IsInfoStepVisible)
                {
                    <div class="bs-card p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold @(ViewModel.TitleHasError ? "text-danger" : "text-secondary")" style="color: var(--text-secondary);">Project Title</label>
                            <input type="text" class="bs-input" placeholder="e.g., Kitchen Remodel" @bind="ViewModel.ProjectTitle" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold @(ViewModel.LocationHasError ? "text-danger" : "text-secondary")" style="color: var(--text-secondary);">Location</label>
                            <input type="text" class="bs-input" placeholder="e.g., New York, NY" @bind="ViewModel.ProjectLocation" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold" style="color: var(--text-muted);">Preferred Site Visit Date (Optional)</label>
                            <BuildSmart.SharedUI.Components.BsCalendar 
                                @bind-Value="ViewModel.PreferredSiteVisitDate" 
                                MinDate="DateTime.Today" 
                                Placeholder="Select a date" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold @(ViewModel.DescriptionHasError ? "text-danger" : "text-secondary")" style="color: var(--text-secondary);">Description</label>
                            <textarea class="bs-input" rows="4" placeholder="Describe your project..." @bind="ViewModel.ProjectDescription"></textarea>
                        </div>

                        <button class="bs-btn-primary mt-3 w-100 fw-bold" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.GoToNextStepCommand.Execute(null)">
                            Next: Select Category
                        </button>
                    </div>
                }

                <!-- Step 1: Category Selection -->
                @if (ViewModel.IsCategoryStepVisible)
                {
                    <BuildSmart.SharedUI.Components.CategorySelector 
                        Categories="ViewModel.SelectableCategories" 
                        HasError="ViewModel.CategorySelectionHasError"
                        IsBusy="ViewModel.IsBusy"
                        NextButtonText="@ViewModel.NextButtonText"
                        OnNextClicked="() => ViewModel.GoToNextStepCommand.Execute(null)" />
                }

                <!-- Dynamic Questions Step -->
                @if (ViewModel.IsQuestionStepVisible)
                {
                    <div class="bs-card p-4">
                        @if (ViewModel.Questions != null)
                        {
                            @foreach (var q in ViewModel.Questions)
                            {
                                <div class="mb-4">
                                    <div class="fw-bold text-uppercase" style="font-size: 0.75rem; color: var(--color-primary);">@q.CategoryName</div>
                                    <label class="form-label fw-bold mb-2 @(q.HasError ? "text-danger" : "")" style="color: var(--text-primary);">
                                        @q.Text
                                        @if (q.IsRequired)
                                        {
                                            <span class="text-danger ms-1">*</span>
                                        }
                                    </label>

                                    @if (q.IsText)
                                    {
                                        <input type="text" class="bs-input" placeholder="Type your answer here..." @bind="q.Answer" />
                                    }
                                    else if (q.IsChoice && q.Options != null)
                                    {
                                        <BuildSmart.SharedUI.Components.BsDropdown 
                                            TValue="string" 
                                            Options="q.Options" 
                                            @bind-Value="q.Answer" 
                                            Placeholder="-- Select an option --" />
                                    }
                                    else if (q.IsBoolean)
                                    {
                                        <div class="form-check" style="display: flex; align-items: center; gap: 10px;">
                                            <input class="form-check-input" type="checkbox" id="@($"check_{q.Id}")" @bind="q.BoolAnswer" style="width: 20px; height: 20px; cursor: pointer; accent-color: var(--color-primary);" />
                                            <label class="form-check-label" for="@($"check_{q.Id}")" style="cursor: pointer; padding-top: 2px; color: var(--text-secondary);">Yes</label>
                                        </div>
                                    }
                                </div>
                            }
                        }

                        <div class="d-flex flex-column gap-3 mt-4">
                            <button class="bs-btn-primary w-100 fw-bold" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.GoToNextStepCommand.Execute(null)">
                                @ViewModel.NextButtonText
                            </button>
                            
                            @if (!ViewModel.IsEditing)
                            {
                                <button class="bs-btn-dark w-100 fw-bold" style="background-color: transparent; border: 1px solid var(--border-color); color: var(--text-primary);" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.GoToPreviousStepCommand.Execute(null)">
                                    Back
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Review Step -->
                @if (ViewModel.IsReviewStepVisible)
                {
                    <div class="bs-card p-4">
                        <h3 class="h4 fw-bold mb-4" style="font-family: var(--font-heading); color: var(--text-primary);">Review &amp; Submit</h3>
                        
                        <div class="mb-3">
                            <span class="fw-bold" style="color: var(--text-secondary);">Title:</span>
                            <div style="font-size: 1.1rem; margin-top: 5px; color: var(--text-primary);">@ViewModel.ProjectTitle</div>
                        </div>

                        <div class="mb-3">
                            <span class="fw-bold" style="color: var(--text-secondary);">Selected Categories:</span>
                            <ul class="list-unstyled mb-0 mt-2" style="padding-left: 15px; color: var(--text-primary);">
                                @if (ViewModel.SelectableCategories != null)
                                {
                                    @foreach (var cat in ViewModel.SelectableCategories.Where(c => c.IsSelected))
                                    {
                                        <li style="margin-bottom: 5px;">&bull; @cat.Category?.Name</li>
                                    }
                                }
                            </ul>
                        </div>

                        <div class="mb-3 mt-4">
                            <span class="fw-bold" style="color: var(--text-secondary);">Job Details:</span>
                            <div class="p-3 rounded mt-2" style="background-color: var(--bg-card-alt); max-height: 250px; overflow-y: auto; border: 1px solid var(--border-color);">
                                @if (ViewModel.AnswersList != null)
                                {
                                    @foreach (var ans in ViewModel.AnswersList)
                                    {
                                        <div class="mb-3">
                                            <div style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2px;">@ans.Key</div>
                                            <div class="fw-bold" style="font-size: 0.95rem; color: var(--text-primary);">@ans.Value</div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-3 mt-4">
                            <button class="bs-btn-primary w-100 fw-bold" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.SubmitProjectCommand.Execute(null)">
                                Post Project
                            </button>
                            
                            <button class="bs-btn-dark w-100 fw-bold" style="background-color: transparent; border: 1px solid var(--border-color); color: var(--text-primary);" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.GoToPreviousStepCommand.Execute(null)">
                                Back
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3">
            <h4>Rendering Error</h4>
            <p>@context.Message</p>
            <pre style="font-size: 10px; overflow-x: auto;">@context.StackTrace</pre>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    protected override void OnInitialized()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        }
    }

    private async void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }

    private string GetSubtitleText()
    {
        if (ViewModel.IsReviewStepVisible) return "Complete all steps to post your project.";
        return ViewModel.CurrentStepTitle;
    }
}



