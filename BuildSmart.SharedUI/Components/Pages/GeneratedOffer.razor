@page "/GeneratedOfferPage"
@using BuildSmart.SharedUI.ViewModels
@using System.ComponentModel
@layout BuildSmart.SharedUI.Components.Layout.MainLayout
@implements IDisposable
@inject GeneratedOfferViewModel ViewModel

<ErrorBoundary>
    <ChildContent>
        @if (ViewModel == null || ViewModel.Job == null && ViewModel.IsBusy)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="container py-4">
                <div class="mb-4">
                    <h2 class="h3 fw-bold mb-2" style="color: var(--text-primary);">Your Smart Offer</h2>
                    <p class="text-muted">Review the detailed breakdown of SKUs and estimated costs for each task.</p>
                </div>

                <div class="p-4 text-center mb-4" style="background-color: var(--bg-card-alt); border: 2px solid var(--color-success); border-radius: 12px;">
                    <div class="d-flex justify-content-center align-items-center gap-3 mb-3">
                        <span class="fw-bold" style="font-size: 1.2rem; color: var(--text-primary);">Total Offer Value:</span>
                        <span class="fw-bold" style="font-size: 1.5rem; color: var(--color-success);">
                            $@ViewModel.TotalEstimatedPrice.ToString("F2")
                        </span>
                    </div>
                    <button class="btn btn-outline-primary fw-bold" @onclick="ToggleBreakdown">
                        @(_showBreakdown ? "Hide Task Breakdowns" : "See Tasks Breakdowns")
                    </button>
                </div>

                @if (_showBreakdown && ViewModel.Tasks != null)
                {
                    <div class="d-flex flex-column gap-4 mb-4">
                        @foreach (var task in ViewModel.Tasks)
                        {
                            <div class="bs-card p-4" style="border-radius: 12px; border-left: 4px solid var(--color-success); border-top: 1px solid var(--border-color); border-right: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="h5 fw-bold mb-0" style="color: var(--text-primary);">@task.Title</h4>
                                    <span class="fw-bold" style="color: var(--color-success); font-size: 1.1rem;">
                                        Total Task Cost: $@task.EstimatedPrice.ToString("F2")
                                    </span>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    <p class="text-muted mb-4" style="font-size: 0.95rem;">@task.Description</p>
                                }

                                <hr style="color: #EEEEEE;" />
                                <h6 class="fw-bold mb-3" style="color: #1565C0;">Billable SKUs & Materials</h6>

                                @if (task.SkuItems != null && task.SkuItems.Count > 0)
                                {
                                    <div class="d-flex flex-column gap-3">
                                        @foreach (var sku in task.SkuItems)
                                        {
                                            <div class="d-flex justify-content-between align-items-center bg-light p-3" style="border-radius: 8px;">
                                                <div class="d-flex align-items-center gap-3">
                                                    <span class="fw-bold" style="color: var(--text-primary);">@(sku.Quantity)x</span>
                                                    <div>
                                                        <div class="fw-bold" style="color: var(--text-primary); font-size: 0.95rem;">@sku.ServiceSku.Name</div>
                                                        <div class="text-muted" style="font-size: 0.8rem;">@sku.ServiceSku.SkuCode</div>
                                                    </div>
                                                </div>
                                                <span class="fw-bold" style="color: var(--color-success);">
                                                    $@sku.EstimatedPrice.ToString("F2")
                                                </span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted" style="font-size: 0.9rem;">No SKUs mapped for this task.</p>
                                }
                            </div>
                        }
                    </div>
                }

                <hr style="color: #E0E0E0; margin: 2rem 0;" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <button class="bs-btn-primary w-100 fw-bold" style="height: 50px; border-radius: 10px; background-color: var(--color-success); border-color: var(--color-success);" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.SubmitToAdminCommand.Execute(null)">
                            Submit to Admin
                        </button>
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-secondary w-100 fw-bold" style="height: 50px; border-radius: 10px;" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.GoBackCommand.Execute(null)">
                            Edit Tasks
                        </button>
                    </div>
                </div>

                @if (ViewModel.IsBusy)
                {
                    <div class="d-flex justify-content-center mt-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-4">
            An error occurred while rendering the Generated Offer overview. Please try refreshing the page.
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    [SupplyParameterFromQuery(Name = "jobId")]
    public Guid? JobId { get; set; }

    private bool _showBreakdown = false;

    private void ToggleBreakdown()
    {
        _showBreakdown = !_showBreakdown;
    }

    protected override void OnInitialized()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        }
    }

    protected override void OnParametersSet()
    {
        if (ViewModel != null)
        {
            var queryParams = new Dictionary<string, object>();
            if (JobId.HasValue) queryParams["JobId"] = JobId.Value;
            
            ViewModel.ApplyQueryAttributes(queryParams);
        }
    }

    private async void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }
}
