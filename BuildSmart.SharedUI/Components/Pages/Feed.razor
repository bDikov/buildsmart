@page "/"
@page "/feed"
@using BuildSmart.SharedUI.ViewModels
@using System.ComponentModel
@using Microsoft.Extensions.Localization
@layout BuildSmart.SharedUI.Components.Layout.MainLayout
@implements IDisposable
@inject FeedPageViewModel ViewModel
@inject NavigationManager NavManager
@inject IStringLocalizer<BuildSmart.SharedUI.Resources.AppResources> Loc

<ErrorBoundary>
    <ChildContent>
        @if (ViewModel == null)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Loc["Feed_Loading"]</span>
                </div>
            </div>
        }
        else
        {
            <div class="container-fluid py-3" style="min-height: 100vh;">
                <!-- Homeowner Action Header -->
                @if (ViewModel.IsHomeowner && ViewModel.HasProjects == false)
                {
                    <div class="mb-4">
                        <button class="bs-btn-primary w-100" @onclick="() => ViewModel.NavigateToWizardCommand.Execute(null)">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            @Loc["Feed_StartNewProject"]
                        </button>
                    </div>
                }

                <!-- Tradesman Feed Header -->
                @if (ViewModel.IsTradesman)
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                        <h2 class="h5 fw-bold mb-0">@Loc["Feed_AvailableAuctions"]</h2>
                        <a href="#" class="text-primary text-decoration-underline" style="font-size: 0.85rem;" @onclick='() => NavManager.NavigateTo("/passed-auctions")' @onclick:preventDefault>
                            @Loc["Feed_DismissedJobs"]
                        </a>
                    </div>
                }

                <!-- Loading Indicator -->
                @if (ViewModel.IsLoading)
                {
                    <div class="text-center my-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">@Loc["Feed_Loading"]</span>
                        </div>
                    </div>
                }
                else
                {
                    <!-- 1. Homeowner View: Pros Directory (Reels) -->
                    @if (ViewModel.IsHomeowner && ViewModel.Tradesmen != null)
                    {
                        <div class="reels-container">
                            @foreach (var tradesman in ViewModel.Tradesmen)
                            {
                                <div class="reel-item" @onclick="() => NavigateToTradesmanProfile(tradesman.Id.ToString())">
                                    <video class="reel-video" src="@tradesman.VideoIntroductionUrl" autoplay loop muted playsinline></video>
                                    
                                    <div class="reel-overlay">
                                        <div class="reel-info">
                                            <h3 class="reel-name">@tradesman.User?.FirstName @tradesman.User?.LastName</h3>
                                            <p class="reel-role">@Loc["Feed_ProfessionalRole"]・@tradesman.User?.Location</p>
                                            
                                            <div class="reel-stats">
                                                <div class="reel-stat-item">
                                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                                    </svg>
                                                    <span>@string.Format("{0:F1}", tradesman.AverageRating)</span>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="reel-actions">
                                            <div class="reel-avatar-ring">
                                                <img src="@(string.IsNullOrEmpty(tradesman.User?.ProfilePictureUrl) ? "dotnet_bot.png" : tradesman.User.ProfilePictureUrl)" alt="Profile" class="reel-avatar-image" />
                                            </div>
                                            <button class="reel-action-btn">
                                                @Loc["Feed_ViewProfile"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- 2. Tradesman View: Available Auctions Feed -->
                    @if (ViewModel.IsTradesman && ViewModel.Auctions != null)
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var auction in ViewModel.Auctions)
                            {
                                <div class="card border-0 shadow-sm rounded-4">
                                    <div class="card-body p-3">
                                        <!-- Job Header -->
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h5 class="fw-bold mb-0" style="font-size: 1.1rem;">@auction.Job?.Title</h5>
                                                <small class="text-primary d-block">@auction.Job?.ServiceCategory?.Name</small>
                                            </div>
                                            <span class="fw-bold text-success" style="font-size: 1.1rem;">
                                                @(auction.Job?.EstimatedBudget != null ? string.Format("{0:C0}", auction.Job.EstimatedBudget.Total) : Loc["Feed_NA"])
                                            </span>
                                        </div>

                                        <!-- Details -->
                                        <p class="mb-3" style="font-size: 0.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            @auction.Job?.Description
                                        </p>
                                        
                                        <div class="d-flex gap-4 mb-3">
                                            <div class="d-flex align-items-center">
                                                <span class="me-1" style="font-size: 0.8rem;">📍</span>
                                                <small class="text-muted">@auction.Job?.Location</small>
                                            </div>
                                            <div class="d-flex align-items-center">
                                                <span class="me-1" style="font-size: 0.8rem;">💬</span>
                                                <small class="text-muted">@string.Format(Loc["Feed_QuestionsCount"], auction.Questions?.Count ?? 0)</small>
                                            </div>
                                        </div>

                                        <!-- Actions -->
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-outline-secondary w-50 py-2" style="border-radius: 8px;" @onclick="() => ViewModel.PassAuctionCommand.Execute(auction)">
                                                @Loc["Feed_Pass"]
                                            </button>
                                            <button class="btn btn-primary w-50 py-2" style="border-radius: 8px;" @onclick="() => ViewModel.NavigateToDetailsCommand.Execute(auction)">
                                                @Loc["Feed_ViewAndBid"]
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3">
            <h4>@Loc["Feed_RenderingError"]</h4>
            <p>@context.Message</p>
            <pre style="font-size: 10px; overflow-x: auto;">@context.StackTrace</pre>
        </div>
    </ErrorContent>
</ErrorBoundary>

<style>
    .reels-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        padding-bottom: 40px;
        width: 100%;
        max-width: 500px;
        margin: 0 auto;
    }

    .reel-item {
        position: relative;
        width: 100%;
        aspect-ratio: 9 / 16;
        background-color: #000;
        border-radius: 20px;
        overflow: hidden;
        cursor: pointer;
        box-shadow: 0px 10px 20px rgba(0,0,0,0.3);
    }

    .reel-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .reel-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
        padding: 30px 20px 20px 20px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        color: white;
    }

    .reel-info {
        display: flex;
        flex-direction: column;
        gap: 6px;
        max-width: 70%;
    }

    .reel-name {
        font-family: var(--font-heading);
        font-size: 20px;
        font-weight: 700;
        margin: 0;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
    }

    .reel-role {
        font-family: var(--font-primary);
        font-size: 14px;
        opacity: 0.9;
        margin: 0;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
    }

    .reel-stats {
        display: flex;
        gap: 15px;
        margin-top: 5px;
    }

    .reel-stat-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 14px;
        font-weight: 600;
    }

    .reel-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }

    .reel-avatar-ring {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        border: 2px solid white;
        overflow: hidden;
    }

    .reel-avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .reel-action-btn {
        background-color: var(--color-primary);
        border: none;
        border-radius: 20px;
        color: white;
        font-weight: bold;
        padding: 8px 16px;
        font-size: 12px;
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .reel-action-btn:hover {
        background-color: #7943e0;
    }
</style>

@code {
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (ViewModel != null)
            {
                ViewModel.PropertyChanged += OnViewModelPropertyChanged;
                await ViewModel.LoadFeedCommand.ExecuteAsync(null);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Console.WriteLine($"[Feed.razor] OnInitializedAsync Error: {ex}");
        }
    }

    private void NavigateToTradesmanProfile(string id) => NavManager.NavigateTo($"/tradesman-profile?TradesmanId={id}");

    private void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }
}
