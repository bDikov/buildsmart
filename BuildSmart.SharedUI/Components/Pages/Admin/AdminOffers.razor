@page "/admin-offers"
@using BuildSmart.SharedUI.GraphQL
@using BuildSmart.SharedUI.ViewModels.Admin
@inject AdminProjectsViewModel ViewModel
@inject NavigationManager NavManager

<div class="page-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="page-title">Project Offers</h2>
    </div>

    <!-- Search & Filters -->
    <div class="bs-card search-card mb-4">
        <div class="search-layout">
            <div class="flex-grow-1">
                <input type="text" class="bs-input search-input" @bind="ViewModel.SearchQuery" @bind:event="oninput" @onkeyup="HandleSearchEnter" placeholder="Search by Project Title, ID, Homeowner Email..." />
            </div>
            <button class="bs-btn-primary" @onclick="TriggerSearch">
                Search
            </button>
            <button class="bs-btn-secondary" @onclick="ClearSearch">
                Clear
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="bs-card mb-4" style="background-color: rgba(244, 67, 54, 0.1); border: 1px solid #F44336;">
            <h4 class="text-danger mb-1">Search Error</h4>
            <p class="text-danger mb-0" style="font-size: 14px;">@ErrorMessage</p>
        </div>
    }

    @if (ViewModel.IsBusy && ViewModel.Projects.Count == 0)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        if (ViewModel.Projects.Count == 0)
        {
            <div class="empty-state">
                <h4 class="text-muted">No projects found</h4>
                <p class="text-muted">There are currently no projects matching your search.</p>
            </div>
        }
        else
        {
            <div class="projects-grid">
                @foreach (var project in ViewModel.Projects)
                {
                    <div class="bs-card project-card">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="project-info">
                                <h3 class="project-title">@project.Title</h3>
                                <p class="project-meta">ID: @project.Id.ToString().Substring(0, 8) • Created: @project.CreatedAt.ToString("MMM dd, yyyy")</p>
                                <p class="project-homeowner">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                    @project.Homeowner.FirstName @project.Homeowner.LastName (@project.Homeowner.Email)
                                </p>
                            </div>
                            <span class="status-badge @project.Status.ToString().ToLower()">@project.Status</span>
                        </div>
                        
                        <hr class="divider" />
                        <p class="project-desc">@project.Description</p>
                        
                        <div class="jobs-list mt-3">
                            @if (project.HasOfferPdf)
                            {
                                <a class="bs-btn-primary btn-sm mb-2" href="/api/offers/@project.Id/download" target="_blank" download>
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                    Download Master Offer PDF
                                </a>
                            }
                            else
                            {
                                <span class="text-danger d-block mb-2" style="font-size: 13px;">No PDF Offer generated yet.</span>
                            }

                            <button class="bs-btn-secondary btn-sm" @onclick="() => HandleRegenerateOffer(project.Id)" disabled="@IsRegenerating">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M2.5 2v6h6M21.5 22v-6h-6M21.34 15.57a10 10 0 1 0-1.57 6.43l3.5-3.5"/></svg>
                                @(IsRegenerating ? "Regenerating..." : "Regenerate Offer")
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private string? ErrorMessage;
    private bool IsRegenerating = false;

    [Inject]
    public IBuildSmartApiClient ApiClient { get; set; } = null!;

    [Inject]
    public IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (ViewModel.Projects.Count == 0)
        {
            await TriggerSearch();
        }
    }

    private async Task HandleSearchEnter(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await TriggerSearch();
        }
    }

    private async Task TriggerSearch()
    {
        ErrorMessage = null;
        try
        {
            await ViewModel.LoadProjectsCommand.ExecuteAsync(null);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task ClearSearch()
    {
        ViewModel.SearchQuery = string.Empty;
        await TriggerSearch();
    }

    private async Task HandleRegenerateOffer(Guid projectId)
    {
        IsRegenerating = true;
        StateHasChanged();
        
        try
        {
            var result = await ApiClient.AdminRegenerateOffer.ExecuteAsync(projectId);
            if (result.Errors?.Count > 0)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Error: " + result.Errors[0].Message);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", "Regeneration started in the background! The page will automatically refresh when the PDF is ready.");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Error: " + ex.Message);
        }
        finally
        {
            IsRegenerating = false;
            StateHasChanged();
        }
    }
}
