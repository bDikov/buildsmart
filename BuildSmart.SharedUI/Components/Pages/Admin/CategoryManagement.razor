@page "/category-management"
@using BuildSmart.SharedUI.ViewModels
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin, ADMIN, admin")]
@inject CategoryManagementViewModel ViewModel
@inject NavigationManager NavManager

<div class="admin-container">
    <div class="header-section">
        <div class="title-group">
            <h1 class="page-title">Category Management</h1>
            <p class="page-subtitle">Manage service categories and global job questions.</p>
        </div>
        <button class="bs-btn-secondary" @onclick="() => ViewModel.LoadCategoriesCommand.ExecuteAsync(null)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Refresh
        </button>
    </div>

    <!-- Global Config -->
    <div class="bs-card global-config-card mb-4">
        <div class="global-info">
            <h3>Global Configuration</h3>
            <p>Manage questions that appear on ALL job posts.</p>
        </div>
        <button class="bs-btn-primary" @onclick="HandleManageGlobalQuestionsAsync">
            Edit Global Questions
        </button>
    </div>

    <!-- Categories List Header -->
    <div class="list-header mt-4">
        <h3>Service Categories</h3>
        <button class="bs-btn-primary" @onclick='() => NavManager.NavigateTo("/category-detail")'>
            + New Category
        </button>
    </div>

    @if (ViewModel.IsBusy && ViewModel.Categories.Count == 0)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading categories...</p>
        </div>
    }
    else if (!ViewModel.Categories.Any())
    {
        <div class="empty-state bs-card mt-3">
            <div class="empty-icon">📁</div>
            <h3>No Categories Found</h3>
            <p>Get started by creating your first service category.</p>
        </div>
    }
    else
    {
        <div class="categories-grid mt-3">
            @foreach (var category in ViewModel.Categories)
            {
                <div class="bs-card category-card" @onclick='() => NavManager.NavigateTo($"/category-detail?id={category.Id}")'>
                    <div class="category-info">
                        <h4 class="category-title">@category.Name</h4>
                        <span class="status-badge @category.Status.ToString().ToLower()">@Loc[$"Status_{category.Status}"]</span>
                    </div>
                    <div class="category-actions">
                        <button class="bs-btn-secondary toggle-btn" @onclick="() => ViewModel.UpdateStatusCommand.ExecuteAsync(category.Id)" @onclick:stopPropagation="true">
                            Toggle Status
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .admin-container {
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 40px;
        gap: 20px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        margin: 0 0 8px 0;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 16px;
        margin: 0;
    }

    .global-config-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(145deg, rgba(81, 43, 212, 0.1), rgba(81, 43, 212, 0.02));
        border: 1px solid rgba(81, 43, 212, 0.2);
    }

    .global-info h3 {
        margin: 0 0 4px 0;
        font-size: 18px;
        font-weight: 700;
    }

    .global-info p {
        margin: 0;
        color: var(--text-muted);
        font-size: 14px;
    }

    .list-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .list-header h3 {
        margin: 0;
        font-size: 20px;
        font-weight: 700;
    }

    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 40px;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 24px;
    }

    .categories-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 16px;
    }

    .category-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .category-card:hover {
        transform: translateY(-2px);
        background-color: var(--bg-card-alt);
    }

    .category-title {
        margin: 0 0 8px 0;
        font-size: 18px;
        font-weight: 700;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.active {
        background: rgba(76, 175, 80, 0.15);
        color: #4CAF50;
    }

    .status-badge.draft {
        background: rgba(158, 158, 158, 0.15);
        color: #9e9e9e;
    }

    .toggle-btn {
        padding: 6px 12px;
        font-size: 12px;
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        // ViewModel loads on instantiation, but we ensure it's loaded if empty
        if (ViewModel.Categories.Count == 0)
        {
            await ViewModel.LoadCategoriesCommand.ExecuteAsync(null);
        }
    }

    private async Task HandleManageGlobalQuestionsAsync()
    {
        // The ViewModel ManageGlobalQuestionsAsync uses AppServiceLocator.Navigation which might not work well with Blazor.
        // Let's reimplement it here directly using NavManager.
        ViewModel.IsBusy = true;
        try
        {
            var apiClient = (IBuildSmartApiClient)ServiceProvider.GetService(typeof(IBuildSmartApiClient))!;
            var result = await apiClient.GetAllServiceCategories.ExecuteAsync();
            var globalCat = result.Data?.AllServiceCategories?.FirstOrDefault(c => c.IsGlobal);

            if (globalCat != null)
            {
                NavManager.NavigateTo($"/category-detail?id={globalCat.Id}");
            }
            else
            {
                NavManager.NavigateTo("/category-detail?isGlobalMode=true");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex);
        }
        finally
        {
            ViewModel.IsBusy = false;
        }
    }
    
    [Inject] IServiceProvider ServiceProvider { get; set; } = default!;
}
