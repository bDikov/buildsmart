@page "/user-management"
@using BuildSmart.SharedUI.ViewModels.Admin
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin, ADMIN, admin")]
@inject UserManagementViewModel ViewModel
@inject NavigationManager NavManager

<div class="admin-container">
    <div class="header-section">
        <div class="title-group">
            <h1 class="page-title">User Management</h1>
            <p class="page-subtitle">Manage system users, roles, and access.</p>
        </div>
        <button class="bs-btn-secondary" @onclick="() => ViewModel.LoadUsersCommand.ExecuteAsync(null)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Refresh
        </button>
    </div>

    @if (ViewModel.IsBusy && ViewModel.Users.Count == 0)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading users...</p>
        </div>
    }
    else if (ViewModel.IsEmpty)
    {
        <div class="empty-state bs-card">
            <div class="empty-icon">👥</div>
            <h3>No Users Found</h3>
            <p>There are currently no users in the system.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="bs-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in ViewModel.Users)
                    {
                        <tr>
                            <td class="font-weight-bold">@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="role-badge @user.Role.ToString().ToLower()">@user.Role</span>
                            </td>
                            <td>
                                <button class="bs-btn-text" @onclick='() => NavManager.NavigateTo($"/user-edit?userId={user.Id}")'>
                                    Edit
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .admin-container {
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 40px;
        gap: 20px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        margin: 0 0 8px 0;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 16px;
        margin: 0;
    }

    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 40px;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 24px;
    }

    .bs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background-color: var(--bg-card);
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    .bs-table th, .bs-table td {
        padding: 16px 24px;
        text-align: left;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-primary);
    }

    .bs-table th {
        background-color: rgba(0, 0, 0, 0.2);
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-muted);
    }

    .bs-table tbody tr:last-child td {
        border-bottom: none;
    }

    .bs-table tbody tr:hover {
        background-color: var(--bg-card-alt);
    }

    .role-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        background: rgba(255,255,255,0.1);
    }

    .role-badge.admin {
        background: rgba(244, 67, 54, 0.15);
        color: #F44336;
    }

    .role-badge.homeowner {
        background: rgba(33, 150, 243, 0.15);
        color: #2196F3;
    }

    .role-badge.tradesman {
        background: rgba(76, 175, 80, 0.15);
        color: #4CAF50;
    }

    .bs-btn-text {
        background: transparent;
        border: none;
        color: var(--color-primary);
        font-weight: 600;
        cursor: pointer;
        padding: 8px 12px;
        border-radius: 6px;
        transition: background 0.2s;
    }

    .bs-btn-text:hover {
        background: rgba(255,255,255,0.05);
    }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        if (ViewModel.Users.Count == 0)
        {
            await ViewModel.LoadUsersCommand.ExecuteAsync(null);
        }
    }
}
