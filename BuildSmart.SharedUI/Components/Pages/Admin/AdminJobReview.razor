        font-size: 18px;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .project-owner {
        font-size: 12px;
        color: var(--text-muted);
    }

    .divider {
        border: 0;
        border-top: 1px solid var(--border-color);
        margin: 15px 0;
    }

    .jobs-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .job-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
