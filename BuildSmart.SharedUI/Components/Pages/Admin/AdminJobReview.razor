        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 20px;
        gap: 20px;
    }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        margin: 0 0 4px 0;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 14px;
        margin: 0;
    }

