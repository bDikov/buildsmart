    .status-badge.underreview { background: rgba(255, 152, 0, 0.15); color: #ff9800; }
</style>

@code {
    protected override void OnInitialized()
    {
        if (ViewModel.Projects.Count == 0)
        {
            ViewModel.LoadJobsCommand.ExecuteAsync(null);
        }
    }

    private async Task HandleApproveJob()
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Approve scope for '{ViewModel.SelectedJob?.Title}'?");
        if (confirm)
        {
            await ApiClient.AdminReviewJobScope.ExecuteAsync(ViewModel.SelectedJob!.Id, true, null);
            ViewModel.CloseDetailsCommand.Execute(null);
            await ViewModel.LoadJobsCommand.ExecuteAsync(null);
        }
    }

    private async Task HandleRejectJob()
    {
        string feedback = await JSRuntime.InvokeAsync<string>("prompt", "Please provide a reason for rejection:", "");
        if (!string.IsNullOrWhiteSpace(feedback))
        {
            await ApiClient.AdminReviewJobScope.ExecuteAsync(ViewModel.SelectedJob!.Id, false, feedback);
            ViewModel.CloseDetailsCommand.Execute(null);
            await ViewModel.LoadJobsCommand.ExecuteAsync(null);
        }
    }

    private async Task HandleDeleteProject(Guid projectId, string title)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete the project '{title}' and all its jobs?");
        if (confirm)
        {
            try
            {
                await ApiClient.DeleteProject.ExecuteAsync(projectId);
                await ViewModel.LoadJobsCommand.ExecuteAsync(null);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to delete project: {ex.Message}");
            }
        }
    }

    private async Task HandleDeleteJob(Guid jobId, string title)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete the job '{title}'?");
        if (confirm)
        {
            try
            {
                await ApiClient.DeleteJobPost.ExecuteAsync(jobId);
                await ViewModel.LoadJobsCommand.ExecuteAsync(null);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to delete job: {ex.Message}");
            }
        }
    }
}
