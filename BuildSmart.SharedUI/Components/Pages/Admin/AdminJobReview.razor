@page "/admin-job-review"
@using BuildSmart.SharedUI.ViewModels.Admin
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin, ADMIN, admin")]
@inject AdminJobReviewViewModel ViewModel
@inject NavigationManager NavManager
@inject IBuildSmartApiClient ApiClient
@inject IJSRuntime JSRuntime

<div class="admin-container">
    <div class="header-section">
        <div class="title-group">
            <h1 class="page-title">Job Scope Reviews</h1>
            <p class="page-subtitle">Review, approve, or reject generated job scopes.</p>
        </div>
        <button class="bs-btn-secondary" @onclick="() => ViewModel.LoadJobsCommand.ExecuteAsync(null)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            Refresh
        </button>
    </div>

    <div class="review-layout">
        <!-- Left Column: Projects & Jobs List -->
        <div class="projects-column">
            @if (ViewModel.IsBusy && ViewModel.Projects.Count == 0)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p>Loading projects...</p>
                </div>
            }
            else if (ViewModel.IsEmpty)
            {
                <div class="empty-state bs-card">
                    <p>No jobs pending review right now.</p>
                </div>
            }
            else
            {
                <div class="projects-list">
                    @foreach (var project in ViewModel.Projects)
                    {
                        <div class="bs-card project-card mb-3">
                            <div class="project-header">
                                <div class="project-info">
                                    <h3 class="project-title">@project.Title</h3>
                                    <span class="project-owner">Owner: @project.Homeowner.FirstName</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="status-badge @project.Status.ToString().ToLower()">@Loc[$"Status_{project.Status}"]</span>
                                    <button class="bs-btn-text text-danger p-0" title="Delete Project" @onclick="() => HandleDeleteProject(project.Id, project.Title)">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </div>
                            
                            <hr class="divider" />
                            
                            <div class="jobs-list">
                                @foreach (var job in project.JobPosts)
                                {
                                    <div class="job-item">
                                        <div class="job-info">
                                            <h4 class="job-title">@job.Title</h4>
                                            <span class="job-category text-muted">@job.ServiceCategory.Name</span>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button class="bs-btn-primary btn-sm" @onclick="() => ViewModel.ViewJobDetailsCommand.Execute(job)">
                                                Review Task
                                            </button>
                                            <button class="bs-btn-text text-danger p-0" title="Delete Job" @onclick="() => HandleDeleteJob(job.Id, job.Title)">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Right Column: Details Panel overlay -->
        @if (ViewModel.IsDetailsVisible && ViewModel.SelectedJob != null)
        {
            var selectedProject = ViewModel.Projects.FirstOrDefault(p => p.JobPosts.Any(j => j.Id == ViewModel.SelectedJob.Id));
            
            <div class="details-panel-overlay">
                <div class="details-panel">
                    <div class="panel-header">
                        <div>
                            <h2>Review Job Scope</h2>
                            @if (selectedProject != null)
                            {
                                <p class="text-primary mb-0">Project: @selectedProject.Title</p>
                                <p class="text-muted mb-0" style="font-size: 12px;">Owner: @selectedProject.Homeowner.FirstName @selectedProject.Homeowner.LastName</p>
                            }
                        </div>
                        <button class="close-btn" @onclick="() => ViewModel.CloseDetailsCommand.Execute(null)">✕</button>
                    </div>

                    <div class="panel-content">
                        <!-- Project Overview -->
                        <div class="content-section">
                            <h4 class="section-heading">Project Context & All Sections</h4>
                            <div class="info-box">
                                @if (selectedProject != null)
                                {
                                    <p class="mb-3">@selectedProject.Description</p>
                                    <h5 class="sub-heading">Project Jobs/Sections:</h5>
                                    <ul class="jobs-bullet-list">
                                        @foreach(var sibling in selectedProject.JobPosts)
                                        {
                                            <li>@sibling.Title <span class="text-muted">(@sibling.Status)</span></li>
                                        }
                                    </ul>
                                }
                            </div>
                        </div>

                        <!-- Rejection Feedback -->
                        @if (!string.IsNullOrEmpty(ViewModel.SelectedJob.AdminFeedback))
                        {
                            <div class="content-section">
                                <h4 class="section-heading text-danger">Previous Rejection Reason</h4>
                                <div class="info-box error-box">
                                    <p class="mb-0">@ViewModel.SelectedJob.AdminFeedback</p>
                                </div>
                            </div>
                        }

                        <!-- Q&A Context -->
                        <div class="content-section">
                            <h4 class="section-heading">Q&A Context (User's Answers)</h4>
                            <div class="info-box dark-box">
                                @if (ViewModel.CurrentJobDetails.Count == 0)
                                {
                                    <p class="text-muted mb-0 italic">No context details available.</p>
                                }
                                else
                                {
                                    @foreach (var qa in ViewModel.CurrentJobDetails)
                                    {
                                        <div class="qa-item">
                                            <p class="qa-question">@qa.Question</p>
                                            <p class="qa-answer">@qa.Answer</p>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Admin Specific Questions -->
                        <div class="content-section">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h4 class="section-heading mb-0">Project-Specific Admin Questions</h4>
                                <button class="bs-btn-text text-primary" @onclick="() => ViewModel.ShowQuestionBuilderCommand.Execute(null)">+ Add Question</button>
                            </div>
                            
                            @if (ViewModel.AdminQuestions.Count == 0)
                            {
                                <p class="text-muted text-center italic mt-2">No custom questions added yet.</p>
                            }
                            else
                            {
                                @foreach (var aq in ViewModel.AdminQuestions)
                                {
                                    <div class="info-box dark-box mb-2">
                                        <p class="qa-question">@aq.Question</p>
                                        <div class="d-flex align-items-center gap-2 mt-1">
                                            <span class="text-muted" style="font-size: 11px;">Answer:</span>
                                            @if (!string.IsNullOrEmpty(aq.Answer))
                                            {
                                                <span class="text-success font-weight-bold" style="font-size: 13px;">@aq.Answer</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning font-weight-bold" style="font-size: 11px;">PENDING</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <!-- Clarifications & Feedback -->
                        <div class="content-section">
                            <h4 class="section-heading">Clarifications & Feedback Thread</h4>
                            @if (ViewModel.SelectedJob.Feedbacks == null || !ViewModel.SelectedJob.Feedbacks.Any())
                            {
                                <p class="text-muted text-center italic mt-2">No clarifications yet.</p>
                            }
                            else
                            {
                                @foreach (var feedback in ViewModel.SelectedJob.Feedbacks)
                                {
                                    <div class="info-box dark-box mb-2 d-flex justify-content-between">
                                        <div>
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <span class="text-primary font-weight-bold" style="font-size: 11px;">@feedback.Author.FirstName:</span>
                                                <span class="text-muted" style="font-size: 10px;">@feedback.CreatedAt.ToString("g")</span>
                                                @if (feedback.IsResolved)
                                                {
                                                    <span class="text-success font-weight-bold" style="font-size: 10px;">RESOLVED</span>
                                                }
                                            </div>
                                            <p class="mb-0" style="font-size: 13px;">@feedback.Text</p>
                                        </div>
                                        @if (!feedback.IsResolved)
                                        {
                                            <button class="bs-btn-secondary btn-sm" @onclick="() => ViewModel.ResolveFeedbackCommand.Execute(feedback.Id)">Resolve</button>
                                        }
                                    </div>
                                }
                            }

                            <!-- Add Feedback -->
                            <div class="d-flex gap-2 mt-3">
                                <input type="text" class="bs-input flex-grow-1" @bind="ViewModel.NewFeedbackText" placeholder="Ask for clarification..." />
                                <button class="bs-btn-primary" @onclick="() => ViewModel.AddFeedbackCommand.Execute(null)">Send</button>
                            </div>
                        </div>

                        <!-- Scope Comparison -->
                        <div class="content-section">
                            <h4 class="section-heading">Scope Review & Comparison</h4>
                            <div class="comparison-grid">
                                <div class="comparison-col">
                                    <h5 class="sub-heading">AI Original:</h5>
                                    <div class="info-box dark-box comparison-box">
                                        <p class="text-muted mb-0" style="font-size: 12px; white-space: pre-wrap;">@ViewModel.SelectedJob.GeneratedScope</p>
                                    </div>
                                </div>

                                <div class="comparison-col">
                                    <h5 class="sub-heading text-success">Homeowner Task Breakdown:</h5>
                                    @if (ViewModel.IsTasksLoading)
                                    {
                                        <div class="spinner-border text-success mx-auto d-block mt-3" role="status"></div>
                                    }
                                    <div class="info-box dark-box border-success comparison-box">
                                        @if (ViewModel.AdminJobTasks.Count == 0 && !ViewModel.IsTasksLoading)
                                        {
                                            <p class="text-muted italic mb-0" style="font-size: 12px;">No structured tasks provided.</p>
                                        }
                                        else
                                        {
                                            @foreach (var task in ViewModel.AdminJobTasks)
                                            {
                                                <div class="mb-3">
                                                    <h6 class="font-weight-bold mb-1" style="font-size: 13px;">@task.Title</h6>
                                                    <p class="text-muted mb-1" style="font-size: 11px;">@task.Description</p>
                                                    <ul class="jobs-bullet-list" style="padding-left: 15px;">
                                                        @foreach(var ac in task.AcceptanceCriteria)
                                                        {
                                                            <li style="font-size: 11px;">@ac.Description</li>
                                                        }
                                                    </ul>
                                                </div>
                                                <hr class="divider" style="margin: 10px 0; border-color: #2D2D2D;" />
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="panel-actions">
                            <button class="bs-btn-success btn-lg flex-grow-1" @onclick="HandleApproveJob">Approve</button>
                            <button class="bs-btn-danger btn-lg flex-grow-1" @onclick="HandleRejectJob">Reject</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Question Builder Modal -->
    @if (ViewModel.IsQuestionBuilderVisible)
    {
        <div class="modal-overlay">
            <div class="bs-card modal-content">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">Add Single Project Question</h3>
                    <button class="close-btn" @onclick="() => ViewModel.CloseQuestionBuilderCommand.Execute(null)">✕</button>
                </div>

                <div class="form-section mb-3">
                    <label class="section-label">Question Text</label>
                    <input type="text" class="bs-input" @bind="ViewModel.BqText" placeholder="e.g. Please specify the ceiling height" />
                </div>

                <div class="d-flex gap-3 mb-3">
                    <div class="form-section flex-grow-1">
                        <label class="section-label">Field Type</label>
                        <select class="bs-select" @bind="ViewModel.BqType">
                            @foreach (var type in ViewModel.QuestionTypes)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="form-section align-items-center justify-content-end pb-2">
                        <label class="d-flex align-items-center gap-2 mb-0 cursor-pointer">
                            <span class="section-label mb-0">Required?</span>
                            <input type="checkbox" style="width: 18px; height: 18px;" @bind="ViewModel.BqIsRequired" />
                        </label>
                    </div>
                </div>

                @if (ViewModel.BqType == "choice" || ViewModel.BqType == "multiselect")
                {
                    <div class="form-section mb-4">
                        <label class="section-label">Choice Options</label>
                        <div class="d-flex gap-2 mb-2">
                            <input type="text" class="bs-input flex-grow-1" @bind="ViewModel.BqNewOptionText" placeholder="Option text..." />
                            <button class="bs-btn-secondary" @onclick="() => ViewModel.AddBqOptionCommand.Execute(null)">Add</button>
                        </div>
                        
                        <div class="d-flex flex-column gap-2">
                            @foreach(var opt in ViewModel.BqOptions)
                            {
                                <div class="d-flex justify-content-between align-items-center bg-dark p-2 rounded">
                                    <span class="font-weight-bold" style="font-size: 14px;">@opt</span>
                                    <button class="bs-btn-text text-danger p-0" @onclick="() => ViewModel.RemoveBqOptionCommand.Execute(opt)">Remove</button>
                                </div>
                            }
                        </div>
                    </div>
                }

                <button class="bs-btn-primary w-100 mt-2" @onclick="() => ViewModel.SubmitNewQuestionCommand.Execute(null)">
                    Add Question to Job
                </button>
            </div>
        </div>
    }
</div>

<style>
