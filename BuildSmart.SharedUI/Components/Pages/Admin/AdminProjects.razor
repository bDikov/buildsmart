@page "/admin-projects"
@using BuildSmart.SharedUI.ViewModels.Admin
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin, ADMIN, admin")]
@inject AdminProjectsViewModel ViewModel
@inject NavigationManager NavManager
@inject IBuildSmartApiClient ApiClient
@inject IJSRuntime JSRuntime

<div class="admin-container">
    <div class="header-section">
        <div class="title-group">
            <h1 class="page-title">All Projects</h1>
            <p class="page-subtitle">View and search all projects across the platform.</p>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="bs-card search-card mb-4">
        <div class="search-layout">
            <div class="flex-grow-1">
                <input type="text" class="bs-input search-input" @bind="ViewModel.SearchQuery" @bind:event="oninput" @onkeyup="HandleSearchEnter" placeholder="Search by Project Title, ID, Homeowner Email, or Name..." />
            </div>
            <button class="bs-btn-primary" @onclick="TriggerSearch">
                Search
            </button>
            <button class="bs-btn-secondary" @onclick="ClearSearch">
                Clear
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="bs-card mb-4" style="background-color: rgba(244, 67, 54, 0.1); border: 1px solid #F44336;">
            <h4 class="text-danger mb-1">Search Error</h4>
            <p class="text-danger mb-0" style="font-size: 14px;">@ErrorMessage</p>
        </div>
    }

    @if (ViewModel.IsBusy && ViewModel.Projects.Count == 0)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading projects...</p>
        </div>
    }
    else if (ViewModel.Projects.Count == 0)
    {
        <div class="empty-state bs-card">
            <div class="empty-icon">📁</div>
            <h3>No Projects Found</h3>
            <p>Adjust your search criteria or wait for new projects.</p>
        </div>
    }
    else
    {
        <div class="projects-list">
            @foreach (var project in ViewModel.Projects)
            {
                <div class="bs-card project-card mb-3">
                    <div class="project-header">
                        <div class="project-info">
                            <h3 class="project-title">@project.Title</h3>
                            <span class="project-owner">Owner: @(project.Homeowner?.FirstName ?? "Unknown") @(project.Homeowner?.LastName ?? "") (@(project.Homeowner?.Email ?? "No Email"))</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="status-badge @project.Status.ToString().ToLower()">@project.Status</span>
                            <button class="bs-btn-text text-danger p-0" title="Delete Project" @onclick="() => HandleDeleteProject(project.Id, project.Title)">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </button>
                        </div>
                    </div>
                    
                    <hr class="divider" />
                    <p class="project-desc">@project.Description</p>
                    
                    <div class="jobs-list mt-3">
                        <button class="bs-btn-secondary btn-sm" @onclick='() => NavManager.NavigateTo($"/admin-job-review")'>
                            View Attached Jobs in Reviews
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .admin-container {
        padding: 40px 20px;
        max-width: 1000px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .header-section {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 32px;
        font-weight: 800;
        margin: 0 0 4px 0;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 14px;
        margin: 0;
    }

    .search-card {
        padding: 20px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }

    .search-layout {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .search-input {
        width: 100%;
        padding: 12px 16px;
        background-color: var(--bg-card-alt);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 15px;
        outline: none;
    }

    .search-input:focus {
        border-color: var(--color-primary);
    }

    .loading-state, .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 40px;
    }

    .empty-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .project-card {
        padding: 20px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }

    .project-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .project-title {
        font-size: 18px;
        font-weight: 700;
        margin: 0 0 4px 0;
    }

    .project-owner {
        font-size: 12px;
        color: var(--text-muted);
    }

    .project-desc {
        font-size: 14px;
        color: var(--text-primary);
        margin: 0;
        white-space: pre-wrap;
    }

    .divider {
        border: 0;
        border-top: 1px solid var(--border-color);
        margin: 15px 0;
    }

    .sub-heading {
        font-size: 13px;
        font-weight: 700;
        color: var(--text-muted);
        margin-bottom: 10px;
    }

    .jobs-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .job-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--bg-card-alt);
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        background: rgba(255,255,255,0.1);
    }
    .status-badge.underreview { background: rgba(255, 152, 0, 0.15); color: #ff9800; }
    .status-badge.active { background: rgba(76, 175, 80, 0.15); color: #4CAF50; }
</style>

@code {
    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (ViewModel.Projects.Count == 0)
        {
            await TriggerSearch();
        }
    }

    private async Task HandleSearchEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await TriggerSearch();
        }
    }

    private async Task TriggerSearch()
    {
        ErrorMessage = null;
        try
        {
            await ViewModel.LoadProjectsCommand.ExecuteAsync(null);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task ClearSearch()
    {
        ViewModel.SearchQuery = string.Empty;
        await TriggerSearch();
    }

    private async Task HandleDeleteProject(Guid projectId, string title)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete the project '{title}' and all its jobs?");
        if (confirm)
        {
            try
            {
                await ApiClient.DeleteProject.ExecuteAsync(projectId);
                await ViewModel.LoadProjectsCommand.ExecuteAsync(null);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to delete project: {ex.Message}");
            }
        }
    }

    private async Task HandleDeleteJob(Guid jobId, string title)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to permanently delete the job '{title}'?");
        if (confirm)
        {
            try
            {
                await ApiClient.DeleteJobPost.ExecuteAsync(jobId);
                await ViewModel.LoadProjectsCommand.ExecuteAsync(null);
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Failed to delete job: {ex.Message}");
            }
        }
    }
}