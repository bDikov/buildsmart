@page "/admin-category-skus"
@using BuildSmart.SharedUI.ViewModels.Admin
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin, ADMIN, admin")]
@inject AdminCategorySkusViewModel ViewModel
@inject NavigationManager NavManager

<div class="admin-container">
    <div class="header-section">
        <div class="title-group">
            <h1 class="page-title">Manage SKUs</h1>
            <p class="page-subtitle">Service SKUs Catalog</p>
        </div>
        <button class="bs-btn-secondary" @onclick='() => NavManager.NavigateTo($"/category-detail?id={ViewModel.CategoryId}")'>
            Back to Category
        </button>
    </div>

    @if (!ViewModel.IsCreatingSku)
    {
        <button class="bs-btn-primary mb-4" @onclick="() => ViewModel.ShowCreateSkuFormCommand.Execute(null)">
            + Add New SKU
        </button>
    }

    @if (ViewModel.IsCreatingSku)
    {
        <div class="bs-card edit-card mb-4">
            <h3 class="section-title mb-4">SKU Details</h3>

            <div class="form-section">
                <label class="section-label">SKU Code</label>
                <input type="text" class="bs-input" @bind="ViewModel.NewSkuCode" placeholder="e.g., ELEC_OUTLET" />
            </div>

            <div class="form-section mt-3">
                <label class="section-label">Name</label>
                <input type="text" class="bs-input" @bind="ViewModel.NewSkuName" placeholder="e.g., Install Outlet" />
            </div>

            <div class="form-section mt-3">
                <label class="section-label">Description (Optional)</label>
                <input type="text" class="bs-input" @bind="ViewModel.NewSkuDescription" placeholder="Description" />
            </div>

            <div class="row-layout mt-3">
                <div class="form-section flex-grow-1 mr-2">
                    <label class="section-label">Base Price</label>
                    <input type="number" step="0.01" class="bs-input" @bind="ViewModel.NewSkuBasePrice" placeholder="e.g., 25.00" />
                </div>

                <div class="form-section flex-grow-1 ml-2">
                    <label class="section-label">Unit Type</label>
                    <select class="bs-select" @bind="ViewModel.NewSkuUnitType">
                        @foreach (var type in ViewModel.AvailableUnitTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button class="bs-btn-secondary mr-3" @onclick="() => ViewModel.CancelCreateSkuCommand.Execute(null)">
                    Cancel
                </button>
                <button class="bs-btn-primary" @onclick="HandleSaveSkuAsync" disabled="@ViewModel.IsBusy">
                    @if (ViewModel.IsBusy)
                    {
                        <span class="spinner-border spinner-border-sm mr-2" role="status" aria-hidden="true"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save SKU</span>
                    }
                </button>
            </div>
        </div>
    }

    @if (ViewModel.IsBusy && ViewModel.Skus.Count == 0 && !ViewModel.IsCreatingSku)
    {
        <div class="loading-state">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Loading SKUs...</p>
        </div>
    }
    else if (ViewModel.Skus.Count == 0)
    {
        <div class="empty-state bs-card">
            <p>No SKUs defined for this category yet.</p>
        </div>
    }
    else
    {
        <div class="skus-list">
            @foreach (var sku in ViewModel.Skus)
            {
                <div class="bs-card sku-card">
                    <div class="sku-info">
                        <span class="sku-code">@sku.SkuCode</span>
                        <h4 class="sku-name">@sku.Name</h4>
                        <div class="sku-pricing mt-2">
                            <span class="sku-price">$@sku.BasePrice.ToString("F2")</span>
                            <span class="sku-unit text-muted ml-2">@sku.UnitType</span>
                        </div>
                    </div>
                    <div class="sku-actions">
                        <button class="bs-btn-text text-primary" @onclick="() => ViewModel.EditSkuCommand.Execute(sku)">
                            Edit
                        </button>
                        <button class="bs-btn-text text-danger" @onclick="() => HandleDeleteSkuAsync(sku.Id)">
                            Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .admin-container {
        padding: 40px 20px;
        max-width: 900px;
        margin: 0 auto;
        min-height: 100vh;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 30px;
        gap: 20px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        margin: 0 0 8px 0;
        color: var(--text-primary);
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        color: var(--text-muted);
        font-size: 16px;
        margin: 0;
    }

    .section-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .edit-card {
        padding: 24px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .row-layout {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
    }

    .section-label {
        font-weight: 700;
        font-size: 14px;
        color: var(--text-primary);
        margin: 0;
    }

    .bs-input, .bs-select {
        width: 100%;
        padding: 12px 16px;
        background-color: var(--bg-card-alt);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

    .bs-input:focus, .bs-select:focus {
        border-color: var(--color-primary);
    }

    .skus-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .sku-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }

    .sku-code {
        font-size: 12px;
        color: #008B8B;
        font-weight: 700;
        display: block;
        margin-bottom: 4px;
    }

    .sku-name {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
    }

    .sku-price {
        color: #4CAF50;
        font-weight: 700;
        font-size: 16px;
    }

    .sku-actions {
        display: flex;
        gap: 12px;
    }

    .form-actions {
        display: flex;
        justify-content: flex-end;
    }

    .mr-2 { margin-right: 8px; }
    .ml-2 { margin-left: 8px; }
    .mr-3 { margin-right: 16px; }
    .mb-4 { margin-bottom: 24px; }
    .mt-2 { margin-top: 8px; }
    .mt-3 { margin-top: 16px; }
    .mt-4 { margin-top: 24px; }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? CategoryId { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(CategoryId))
        {
            ViewModel.CategoryId = CategoryId;
            ViewModel.LoadSkusCommand.ExecuteAsync(null);
        }
    }

    private async Task HandleSaveSkuAsync()
    {
        await ViewModel.SaveNewSkuCommand.ExecuteAsync(null);
    }

    [Inject] IJSRuntime JSRuntime { get; set; } = default!;

    private async Task HandleDeleteSkuAsync(Guid skuId)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Delete this SKU?");
        if (confirm)
        {
            // The ViewModel has DeleteSkuCommand taking skuId
            await ViewModel.DeleteSkuCommand.ExecuteAsync(skuId);
        }
    }
}
