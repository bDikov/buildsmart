@page "/scope-review"
@using BuildSmart.SharedUI.ViewModels
@using System.ComponentModel
@layout BuildSmart.SharedUI.Components.Layout.MainLayout
@implements IDisposable
@inject ScopeReviewViewModel ViewModel

<ErrorBoundary>
    <ChildContent>
        @if (ViewModel == null || ViewModel.Job == null && ViewModel.IsBusy)
        {
            <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else
        {
            <div class="container py-4">
                <div class="mb-4">
                    <h2 class="h3 fw-bold mb-2" style="color: var(--text-primary);">AI Generated Scope Reference</h2>
                    <p class="text-muted">Use the AI suggestion below to break your project into specific tasks.</p>
                </div>

                @if (!string.IsNullOrEmpty(ViewModel.GeneratedScope))
                {
                    string scopeClass = _isScopeExpanded ? "scope-view expanded" : "scope-view collapsed";
                    <div class="bs-card p-4 mb-5" style="background-color: var(--bg-card-alt); border: 1px solid var(--border-color); border-radius: 12px;">
                        <div class="@scopeClass">
                            <div class="scope-text" style="font-size: 0.95rem; line-height: 1.6;">
                                @((MarkupString)Markdig.Markdown.ToHtml(ViewModel.GeneratedScope))
                            </div>
                        </div>
                        <button class="btn btn-link p-0 mt-3 text-decoration-none shadow-none fw-bold" style="color: var(--color-primary);" @onclick="ToggleScopeExpansion">
                            @(_isScopeExpanded ? "View Less" : "View More")
                        </button>
                    </div>
                }

                <div class="mb-4">
                    <h3 class="h4 fw-bold mb-1" style="color: var(--text-primary);">Task Breakdown (Agile Bidding)</h3>
                    <p class="text-muted" style="font-size: 0.95rem;">Tradesmen will bid on these specific tasks. Define what needs to be done and how you will accept the work.</p>
                </div>

                <!-- List of Tasks -->
                @if (ViewModel.Tasks != null)
                {
                    <div class="d-flex flex-column gap-4 mb-4">
                        @foreach (var task in ViewModel.Tasks)
                        {
                            <div class="bs-card task-card p-4" style="border-radius: 12px; background-color: var(--bg-card);">
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge text-white px-3 py-2" style="background-color: var(--color-primary); font-size: 0.9rem; border-radius: 8px;">Task #@task.SequenceOrder</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (task.EstimatedPrice > 0)
                                        {
                                            <div class="fw-bold text-success px-3 py-2" style="background-color: rgba(76, 175, 80, 0.1); border-radius: 8px; font-size: 0.9rem;">
                                                Cost: @task.EstimatedPrice.ToString("C2")
                                            </div>
                                        }
                                        <button class="btn btn-outline-danger btn-sm px-3 fw-bold" style="border-radius: 8px;" @onclick="() => ViewModel.RemoveTaskCommand.Execute(task)">
                                            Remove
                                        </button>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Task Title</label>
                                    <input type="text" class="bs-input fw-bold" placeholder="e.g., Demolition of old cabinets" @bind="task.Title" style="font-size: 1.05rem;" />
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Description (Optional)</label>
                                    <textarea class="bs-input" rows="2" placeholder="Add detailed instructions or materials..." @bind="task.Description" style="font-size: 0.95rem;"></textarea>
                                </div>
                                
                                <div class="mt-3">
                                    <div class="fw-bold mb-2" style="color: var(--text-primary); font-size: 0.9rem;">
                                        Acceptance Criteria (Definition of Done)
                                    </div>

                                    <!-- List of Criteria within a Task -->
                                    @if (task.Criteria != null)
                                    {
                                        <div class="d-flex flex-column gap-2 mb-2">
                                            @foreach (var criteria in task.Criteria)
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <span style="color: var(--text-muted); font-size: 1.2rem; line-height: 1;">&bull;</span>
                                                    <input type="text" class="bs-input flex-grow-1" placeholder="e.g., Debris is completely removed from site" @bind="criteria.Description" style="font-size: 0.9rem;" />
                                                    <button class="btn text-danger shadow-none p-0 d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; border-radius: 8px; background-color: rgba(220, 53, 69, 0.1); border: 1px solid transparent; font-size: 1.2rem;" @onclick="() => task.RemoveCriteriaCommand.Execute(criteria)" title="Remove criterion">
                                                        &times;
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <button class="btn btn-link p-0 shadow-none fw-bold" style="color: var(--color-primary); font-size: 0.85rem; text-decoration: none;" @onclick="() => task.AddCriteriaCommand.Execute(null)">
                                        + Add Criterion
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }

                <button class="btn w-100 fw-bold mb-5" style="background-color: transparent; border: 2px dashed var(--color-primary); color: var(--color-primary); padding: 16px; border-radius: 12px; font-size: 1.05rem;" @onclick="() => ViewModel.AddTaskCommand.Execute(null)">
                    + Add Another Task
                </button>

                <div class="bs-card p-4 text-center mb-4" style="background-color: var(--bg-card-alt); border-radius: 12px;">
                    <h4 class="fw-bold mb-3" style="color: var(--text-primary);">Ready to receive offers?</h4>
                    <p class="text-muted mb-4">Once your tasks are broken down, we'll generate an offer format that tradesmen can easily bid on.</p>
                    <div class="row g-3 justify-content-center">
                        <div class="col-md-5">
                            <button class="btn btn-outline-secondary w-100 fw-bold" style="height: 50px; border-radius: 10px;" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.BackToEditAnswersCommand.Execute(null)">
                                Back to Answers
                            </button>
                        </div>
                        <div class="col-md-5">
                            <button class="bs-btn-primary w-100 fw-bold" style="height: 50px; border-radius: 10px;" disabled="@ViewModel.IsBusy" @onclick="() => ViewModel.ApproveCommand.Execute(null)">
                                Generate Offer
                            </button>
                        </div>
                    </div>
                </div>

                @if (ViewModel.IsBusy)
                {
                    <div class="d-flex justify-content-center mt-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Processing...</span>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3">
            <h4>Rendering Error</h4>
            <p>@context.Message</p>
        </div>
    </ErrorContent>
</ErrorBoundary>

<style>
    .scope-view.collapsed {
        max-height: 200px;
        overflow: hidden;
        position: relative;
    }
    .scope-view.collapsed::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 100px;
        background: linear-gradient(transparent, var(--bg-card-alt) 95%);
        pointer-events: none;
    }
    
    .scope-text {
        font-size: 1rem;
        line-height: 1.6;
        color: var(--text-secondary);
        max-width: 75ch; /* Cap width for readability */
    }

    ::deep .scope-text p {
        color: var(--text-secondary);
        margin-top: 0;
        margin-bottom: 1.25rem;
    }

    ::deep .scope-text h1, 
    ::deep .scope-text h2, 
    ::deep .scope-text h3, 
    ::deep .scope-text h4 {
        color: var(--text-primary);
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    ::deep .scope-text h1 { font-size: 1.5rem; border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; }
    ::deep .scope-text h2 { font-size: 1.25rem; }
    ::deep .scope-text h3 { font-size: 1.125rem; }
    ::deep .scope-text h4 { font-size: 1rem; }

    ::deep .scope-text ul, ::deep .scope-text ol {
        margin-top: 0;
        margin-bottom: 1.25rem;
        padding-left: 1.5rem;
    }

    ::deep .scope-text li {
        margin-bottom: 0.5rem;
    }

    ::deep .scope-text strong {
        color: var(--text-primary);
        font-weight: 600;
    }

    ::deep .scope-text blockquote {
        border-left: 4px solid var(--color-primary);
        padding: 0.5rem 0 0.5rem 1rem;
        margin: 1.5rem 0;
        color: var(--text-muted);
        font-style: italic;
        background: rgba(0, 0, 0, 0.02);
        border-radius: 0 0.5rem 0.5rem 0;
    }

    .task-card {
        border: 1px solid var(--border-color);
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }
    .task-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.08);
        border-color: var(--color-primary);
    }
    .bs-input:focus {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 0.2rem rgba(var(--color-primary-rgb), 0.25);
    }
</style>

@code {
    [SupplyParameterFromQuery] public Guid? JobId { get; set; }

    private bool _isScopeExpanded = false;

    private void ToggleScopeExpansion()
    {
        _isScopeExpanded = !_isScopeExpanded;
    }

    protected override void OnInitialized()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        }
    }

    protected override void OnParametersSet()
    {
        if (ViewModel != null)
        {
            var queryParams = new Dictionary<string, object>();
            if (JobId.HasValue) queryParams["JobId"] = JobId.Value;
            
            ViewModel.ApplyQueryAttributes(queryParams);
        }
    }

    private async void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }
}