@page "/project-detail"
@using BuildSmart.SharedUI.ViewModels
@using BuildSmart.SharedUI.GraphQL
@using System.ComponentModel
@using BuildSmart.SharedUI.Components
@layout BuildSmart.SharedUI.Components.Layout.MainLayout
@implements IDisposable
@inject ProjectDetailViewModel ViewModel
@inject NavigationManager NavManager

<ErrorBoundary>
    <ChildContent>
        <div class="project-detail-container">
            @if (!ViewModel.HasLoaded)
            {
                <div class="loading-state">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>@Loc["ProjectDetail_Loading"]</p>
                </div>
            }
            else if (ViewModel.Project != null)
            {
                <!-- Header -->
                <div class="header-section">
                    <button class="back-btn" @onclick="GoBack">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                    </button>
                    <div class="header-content">
                        <h2 class="page-title">@ViewModel.Project.Title</h2>
                        <span class="status-badge status-@(ViewModel.Project.Status.ToString().ToLower())">@Loc[$"Status_{ViewModel.Project.Status}"]</span>
                    </div>
                </div>

                <ProjectOverviewCard 
                    Project="ViewModel.Project" 
                    IsMasterOfferReady="IsMasterOfferReady()" 
                    OnDownloadMasterOffer="DownloadMasterOffer" 
                    OnContinueDraft='() => NavManager.NavigateTo($"/job-wizard?projectId={ViewModel.Project.Id}")' />

                <h3 class="section-title">@Loc["ProjectDetail_JobsTitle"]</h3>

                <div class="job-posts-list">
                    @if (ViewModel.JobPosts == null || !ViewModel.JobPosts.Any())
                    {
                        <p class="text-muted fst-italic">@Loc["ProjectDetail_NoJobs"]</p>
                    }
                    else
                    {
                        @foreach (var jobVm in ViewModel.JobPosts)
                        {
                            <JobPostCard 
                                JobVm="jobVm" 
                                IsExpanded="_expandedJobs.Contains(jobVm.JobPost.Id)" 
                                OnToggleExpansion="() => ToggleJobExpansion(jobVm.JobPost.Id)" 
                                OnSeeTasks='() => NavManager.NavigateTo($"/GeneratedOfferPage?jobId={jobVm.JobPost.Id}")'
                                OnViewAuctionHub="() => ViewModel.ViewAuctionHubCommand.ExecuteAsync(jobVm.JobPost)"
                                OnViewAIOffer='() => NavManager.NavigateTo($"/GeneratedOfferPage?jobId={jobVm.JobPost.Id}")' />
                        }
                    }
                </div>
            }
        </div>
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3">
            <h4>Rendering Error</h4>
            <p>@context.Message</p>
        </div>
    </ErrorContent>
</ErrorBoundary>

@code {
    [SupplyParameterFromQuery]
    public Guid? ProjectId { get; set; }
    
    [SupplyParameterFromQuery]
    public Guid? JobId { get; set; }

    private HashSet<Guid> _expandedJobs = new();

    private void ToggleJobExpansion(Guid jobId)
    {
        if (_expandedJobs.Contains(jobId))
            _expandedJobs.Remove(jobId);
        else
            _expandedJobs.Add(jobId);
            
        InvokeAsync(StateHasChanged);
    }

    private bool IsMasterOfferReady()
    {
        if (ViewModel.Project == null)
            return false;

        if (!ViewModel.Project.HasOfferPdf)
            return false;

        if (ViewModel.Project.JobPosts != null && ViewModel.Project.JobPosts.Any(jp => 
            jp.Status == JobPostStatus.Draft || 
            jp.Status == JobPostStatus.GeneratingScope || 
            jp.Status == JobPostStatus.Rejected))
        {
            return false;
        }

        return true;
    }
    private void DownloadMasterOffer()
    {
        if (ViewModel.Project != null)
        {
            var url = $"{ApiConfig.GetBaseUrl()}/api/offers/{ViewModel.Project.Id}/download";
            NavManager.NavigateTo(url, forceLoad: true);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        
        var query = new Dictionary<string, object>();
        if (ProjectId.HasValue) query["ProjectId"] = ProjectId.Value;
        if (JobId.HasValue) query["JobId"] = JobId.Value;
        
        ViewModel.ApplyQueryAttributes(query);
    }

    private void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void GoBack()
    {
        NavManager.NavigateTo("..");
    }

    public void Dispose()
    {
        if (ViewModel != null)
        {
            ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        }
    }
}

<style>
    /* 
       INLINE STYLES TO BYPASS BLAZOR SCOPED CSS BUNDLE CACHING ON WEB 
       This guarantees the container has padding from the edges of the screen.
    */
    .project-detail-container {
        max-width: 800px !important;
        margin: 0 auto !important;
        padding: 24px !important;
        width: 100% !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
    }

    @@media (max-width: 768px) {
        .project-detail-container {
            padding: 16px !important;
        }
    }

    /* Force all inner cards to respect padding */
    .project-detail-container .bs-card {
        padding: 24px !important;
        width: 100% !important;
        box-sizing: border-box !important;
        overflow-x: hidden !important;
    }

    /* Force all text elements to wrap safely */
    .project-detail-container p, 
    .project-detail-container .project-description, 
    .project-detail-container .job-description, 
    .project-detail-container .scope-text {
        word-break: break-word !important;
        overflow-wrap: break-word !important;
        max-width: 100% !important;
    }
</style>
