@page "/login"
@using BuildSmart.SharedUI.ViewModels
@attribute [AllowAnonymous]
@layout BuildSmart.SharedUI.Components.Layout.BlankLayout
@inject LoginPageViewModel ViewModel
@inject Microsoft.AspNetCore.Components.NavigationManager NavManager
@inject BuildSmart.SharedUI.Services.IAuthService AuthService
@inject IServiceProvider ServiceProvider

<div class="login-container">
    <div class="login-card bs-card">
        
        <h2 class="login-title">@Loc["Login_LoginWith"]</h2>

        <div class="social-login-container">
            <button class="social-btn bs-btn-dark" @onclick="() => ViewModel.GoogleLoginCommand.ExecuteAsync(null)">
                <svg width="25" height="25" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                @Loc["Login_Google"]
            </button>
        </div>

        <div class="divider">
            <span>@Loc["Login_Or"]</span>
        </div>

        <div class="form-group">
            <label class="form-label">@Loc["Login_Email"]</label>
            <input type="email" class="bs-input login-input" placeholder="@Loc["Login_EmailPlaceholder"]" @bind="ViewModel.Email" />
        </div>

        <div class="form-group">
            <label class="form-label">@Loc["Login_Password"]</label>
            <input type="password" class="bs-input login-input" placeholder="@Loc["Login_PasswordPlaceholder"]" @bind="ViewModel.Password" />
        </div>

        <button class="bs-btn-primary login-btn" @onclick="() => ViewModel.LoginCommand.ExecuteAsync(null)">
            @Loc["Login_LogInButton"]
        </button>

        <div class="signup-prompt">
            <span>@Loc["Login_NoAccountPrompt"]<a href="#" @onclick="() => ViewModel.CreateAccountCommand.Execute(null)" @onclick:preventDefault>@Loc["Login_SignUp"]</a></span>
        </div>

    </div>
</div>

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100dvh;
        background-color: var(--bg-page);
        font-family: var(--font-primary);
        margin: 0;
        padding: 0;
    }

    .login-card {
        width: 100%;
        max-width: 425px;
        padding: 40px;
        display: flex;
        flex-direction: column;
        gap: 25px;
        box-sizing: border-box;
    }

    @@media (max-width: 480px) {
        .login-container {
            align-items: flex-start;
        }
        .login-card {
            height: 100dvh;
            padding: 20px 20px 40px 20px;
            justify-content: center;
            border-radius: 0;
            border: none;
            box-shadow: none;
            margin: 0;
            max-width: 100%;
        }
    }

    .login-title {
        color: var(--text-primary);
        font-size: 20px;
        font-weight: 600;
        margin: 0;
        text-align: center;
        opacity: 0.9;
        font-family: var(--font-heading);
    }

    .social-login-container {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        gap: 15px;
    }

    .social-btn {
        flex: 1;
        height: 58px;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        font-size: 16px;
        font-weight: 600;
    }

    .divider {
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 10px 0;
    }

    .divider span {
        color: var(--text-primary);
        font-size: 14px;
        font-weight: 500;
        opacity: 0.9;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .form-label {
        color: var(--text-primary);
        font-size: 16px;
        font-weight: 500;
        opacity: 0.9;
    }

    .login-input {
        height: 58px;
        padding: 0 15px;
    }

    .login-btn {
        height: 58px;
        font-weight: 500;
        font-size: 18px;
        margin-top: 15px;
        width: 100%;
    }

    .signup-prompt {
        text-align: center;
        margin-top: 10px;
    }

    .signup-prompt span {
        color: var(--text-primary);
        font-size: 16px;
        font-weight: 500;
    }

    .signup-prompt a {
        color: var(--color-primary);
        font-weight: 600;
        text-decoration: none;
    }

    .signup-prompt a:hover {
        text-decoration: underline;
    }
</style>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Extract token safely
        string? actualToken = Token;
        if (string.IsNullOrEmpty(actualToken))
        {
            var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
            if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var tokenValues))
            {
                actualToken = tokenValues.FirstOrDefault();
            }
        }

        if (!string.IsNullOrEmpty(actualToken))
        {
            try
            {
                // Save the token securely
                await AuthService.SaveTokenAsync(actualToken);

                // Notify the application that the user is now logged in
                var authStateProvider = ServiceProvider.GetService(typeof(Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider)) as BuildSmart.SharedUI.Services.MauiAuthenticationStateProvider;
                authStateProvider?.NotifyAuthenticationStateChanged();

                // Force load to ensure the browser sends the new cookie to the server
                NavManager.NavigateTo("/", forceLoad: true);
            }
            catch (Microsoft.AspNetCore.Components.NavigationException)
            {
                // Blazor uses this exception to execute the redirect, we MUST rethrow it!
                throw;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Login] Failed to process token: {ex.Message}");
            }        }
    }
}
