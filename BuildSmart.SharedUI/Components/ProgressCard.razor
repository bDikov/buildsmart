<div class="progress-card-container">
    <div class="progress-card-shadow"></div>
    <div class="progress-card-main bs-card">
        <h2 class="progress-title">@Title</h2>
        <div class="progress-content">
            <div class="circular-progress">
                <svg viewBox="0 0 118 118" class="circular-chart">
                    <!-- Drop shadow definition for the glow -->
                    <defs>
                        <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
                            <feGaussianBlur stdDeviation="4" result="blur" />
                            <feComposite in="SourceGraphic" in2="blur" operator="over" />
                        </filter>
                    </defs>
                    <!-- Neumorphic-like track using a softer secondary background -->
                    <circle class="circular-bg" cx="59" cy="59" r="51"></circle>
                    <circle class="circular-fill" cx="59" cy="59" r="51" stroke-dashoffset="@CalculateOffset()"></circle>
                </svg>
                <div class="circular-text">@(Math.Max(0, (int)Math.Round(_displayPercentage)))%</div>
            </div>
            <div class="progress-info">
                <div class="progress-step">@StepText</div>
                <div class="progress-subtitle">@SubtitleText</div>
            </div>
        </div>
    </div>
</div>

<style>
    .progress-card-container {
        position: relative;
        width: 100%;
        margin-bottom: 40px;
        font-family: var(--font-primary);
    }

    .progress-card-shadow {
        position: absolute;
        top: 20px;
        left: 20px;
        width: calc(100% - 20px);
        height: 100%;
        background-color: var(--color-primary); /* Uses the theme purple */
        opacity: 0.3;
        border-radius: 30px;
        z-index: 0;
    }

    .progress-card-main {
        position: relative;
        background-color: var(--bg-card);
        border-radius: 30px;
        padding: 35px 45px;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 25px;
        box-shadow: var(--shadow-main);
    }

    .progress-title {
        font-family: var(--font-heading);
        font-size: 26px;
        font-weight: 900;
        color: var(--text-primary);
        margin: 0;
    }

    .progress-content {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 20px;
    }

    .circular-progress {
        position: relative;
        width: 118px;
        height: 118px;
        flex-shrink: 0;
        /* Soft inner background for a neumorphic feel */
        background-color: var(--bg-card);
        border-radius: 50%;
        box-shadow: inset 4px 4px 8px rgba(0, 0, 0, 0.05), inset -4px -4px 8px rgba(255, 255, 255, 0.05);
    }

    .circular-chart {
        display: block;
        margin: 0 auto;
        max-width: 100%;
        max-height: 100%;
    }

    .circular-bg {
        fill: none;
        stroke: var(--bg-card-alt);
        stroke-width: 10;
    }

    .circular-fill {
        fill: none;
        stroke: var(--color-primary);
        stroke-width: 10;
        stroke-linecap: round;
        /* Bouncy spring animation */
        transition: stroke-dashoffset 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        stroke-dasharray: 320.44; /* Circumference of circle with r=51 (2 * pi * 51) */
        transform: rotate(-90deg);
        transform-origin: 50% 50%;
        filter: url(#glow);
    }

    .circular-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-size: 28px;
        font-weight: 900;
        color: var(--text-primary);
        font-family: var(--font-primary);
    }

    .progress-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
        justify-content: center;
    }

    .progress-step {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .progress-subtitle {
        font-size: 18px;
        font-weight: 500;
        color: var(--text-secondary);
        margin: 0;
    }

    /* Responsive adjustments */
    @@media (max-width: 600px) {
        .progress-card-main {
            padding: 25px;
        }
        .progress-content {
            flex-direction: column;
            align-items: flex-start;
            text-align: center;
        }
        .progress-info {
            align-items: center;
            width: 100%;
        }
    }
</style>

@code {
    [Parameter]
    public string Title { get; set; } = "Your progress";

    [Parameter]
    public double ProgressPercentage { get; set; }

    [Parameter]
    public string StepText { get; set; } = "Step X of Y complete";

    [Parameter]
    public string SubtitleText { get; set; } = "Complete all steps to finish.";

    private double _displayPercentage = 0;
    private CancellationTokenSource? _animationCts;
    private double _lastTarget = -1;

    protected override void OnInitialized()
    {
        _displayPercentage = Math.Max(0, Math.Min(100, ProgressPercentage));
        _lastTarget = _displayPercentage;
    }

    protected override void OnParametersSet()
    {
        double target = Math.Max(0, Math.Min(100, ProgressPercentage));
        if (Math.Abs(target - _lastTarget) > 0.01)
        {
            _lastTarget = target;
            
            // Start the animation loop if it's not already running
            if (_animationCts == null || _animationCts.IsCancellationRequested)
            {
                _animationCts = new CancellationTokenSource();
                _ = AnimateTextAsync(_animationCts.Token);
            }
        }
    }

    private async Task AnimateTextAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                double target = Math.Max(0, Math.Min(100, ProgressPercentage));
                double diff = target - _displayPercentage;

                if (Math.Abs(diff) < 0.5)
                {
                    _displayPercentage = target;
                    StateHasChanged();
                    break; // Target reached, stop loop
                }

                // Smooth ease-out lerp tracking the target continuously
                _displayPercentage += diff * 0.15;
                StateHasChanged();
                
                await Task.Delay(16, token); // ~60fps
            }
        }
        catch (OperationCanceledException)
        {
            // Ignored, normal cancellation
        }
        finally
        {
            _animationCts?.Cancel();
        }
    }

    private string CalculateOffset()
    {
        // Total circumference of circle with radius 51 is ~320.44
        double circumference = 320.44;
        
        // Ensure progress is bounded
        double progress = Math.Max(0, Math.Min(100, ProgressPercentage));
        
        // Calculate offset (100% = 0 offset, 0% = full circumference offset)
        double offset = circumference - (progress / 100.0) * circumference;
        
        // Format with InvariantCulture so decimals use '.' instead of ',' (fixes SVG in EU locales)
        return offset.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }
}