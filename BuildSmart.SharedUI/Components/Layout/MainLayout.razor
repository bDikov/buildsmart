@inherits LayoutComponentBase
@using BuildSmart.SharedUI.Services
@using BuildSmart.SharedUI.GraphQL
@using Microsoft.AspNetCore.Components.Authorization
@inject INavigationBridge NavigationBridge
@inject IAuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IBlazorNavigationRegistry NavigationRegistry
@inject IBuildSmartApiClient ApiClient

<div class="page">
    <!-- Mobile Header -->
    <div class="mobile-header">
        <div class="logo-block">
            <div class="logo-icon" style="width: 32px; height: 32px;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                </svg>
            </div>
            <span class="logo-text" style="font-size: 16px;">BuildSmart</span>
        </div>
        
        <div style="display: flex; align-items: center; gap: 8px;">
            <a class="notification-bell mobile-bell" href="/notifications">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
            </a>
            
            <button class="mobile-menu-btn" @onclick="ToggleSidebar">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>

    <div class="sidebar-overlay @(_isSidebarOpen ? "open" : "")" @onclick="CloseSidebar"></div>

    <div class="sidebar shadow-sm @(_isSidebarOpen ? "open" : "")">
        <div class="sidebar-header">
            <div class="logo-block">
                <div class="logo-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                    </svg>
                </div>
                <span class="logo-text">BuildSmart</span>
            </div>
        </div>



        <div class="nav flex-column sidebar-nav">
            
            <!-- Standard Blazor Links -->
            <a class="nav-item-dark" href="feed" @onclick="CloseSidebar">
                <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                @Loc["Nav_Marketplace"]
            </a>

            <!-- Role-based Native XAML Bridges & Blazor Pages -->
            <AuthorizeView Roles="Homeowner, HOMEOWNER, homeowner, Tradesman, TRADESMAN, tradesman">
                <a class="nav-item-dark" href="/my-projects" @onclick="CloseSidebar">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                    @Loc["Nav_MyProjects"]
                </a>
                <!-- Temporarily hidden
                <a class="nav-item-dark" href="/active-jobs" @onclick="CloseSidebar">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
                    @Loc["Nav_ActiveJobs"]
                </a>
                -->
            </AuthorizeView>

            <AuthorizeView Roles="Admin, ADMIN, admin">
                <div class="nav-item-header mt-4 mb-2">
                    @Loc["Nav_ManageHeader"]
                </div>
                <a class="nav-item-dark" href="/category-management" @onclick="CloseSidebar">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    @Loc["Nav_Categories"]
                </a>
                <a class="nav-item-dark" href="/user-management" @onclick="CloseSidebar">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    @Loc["Nav_Users"]
                </a>
                <a class="nav-item-dark" href="/admin-job-review" @onclick="CloseSidebar">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    @Loc["Nav_JobReviews"]
                </a>
            </AuthorizeView>

        </div>

        <div class="sidebar-account">
            <a href="/user-profile" class="account-info" @onclick="CloseSidebar" style="text-decoration: none; cursor: pointer;">
                <div class="account-avatar" style="overflow: hidden;">
                    @if (!string.IsNullOrEmpty(_userProfilePictureUrl))
                    {
                        <img src="@_userProfilePictureUrl" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <!-- Generic user icon -->
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    }
                </div>
                <div class="account-details">
                    <span class="account-name">@(_userName ?? "BuildSmart User")</span>
                    <span class="account-email">@(_userEmail ?? "user@buildsmart.com")</span>
                </div>
            </a>
            <button class="logout-btn" @onclick="LogoutAsync" @onclick:preventDefault title="Logout">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            </button>
        </div>
    </div>

    <main class="main-content">
        <div class="top-app-bar desktop-top-bar">
            <div class="spacer"></div>
            <a class="notification-bell desktop-notification-bell" href="/notifications">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
            </a>
        </div>
        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

<style>
    .sidebar {
        background-color: var(--bg-card);
        border-right: 1px solid var(--border-color);
        min-height: 100vh;
        width: 312px;
        position: fixed;
        top: 0;
        left: 0;
        display: flex;
        flex-direction: column;
        color: var(--text-primary);
        font-family: 'Inter', var(--font-primary);
        z-index: 100;
        transition: transform 0.3s ease;
    }

    .sidebar-header {
        padding: 24px 16px;
    }

    .logo-block {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-icon {
        width: 40px;
        height: 40px;
        background-color: var(--text-primary);
        color: var(--bg-card);
        border-radius: 4px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .logo-text {
        font-size: 18px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .sidebar-search {
        margin: 0 16px 24px 16px;
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        height: 40px;
        display: flex;
        align-items: center;
        padding: 0 12px;
        gap: 12px;
    }

    .search-icon {
        color: var(--text-muted);
    }

    .search-input {
        background: transparent;
        border: none;
        color: var(--text-primary);
        font-size: 16px;
        width: 100%;
        outline: none;
    }

    .search-input::placeholder {
        color: var(--text-muted);
    }

    .sidebar-nav {
        padding: 0 16px;
        flex-grow: 1;
        overflow-y: auto;
    }

    .nav-item-dark {
        height: 40px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        padding: 0 12px;
        cursor: pointer;
        color: var(--text-muted);
        text-decoration: none;
        transition: background-color 0.2s ease, color 0.2s ease;
        font-size: 14px;
        font-weight: 500;
        gap: 12px;
        margin-bottom: 4px;
    }

    .nav-item-dark:hover, .nav-item-dark:focus {
        background-color: var(--bg-card-alt);
        color: var(--text-primary);
    }

    .nav-item-dark:active {
        background-color: var(--color-primary);
        color: var(--bg-card);
    }

    .nav-icon {
        opacity: 0.8;
    }

    .nav-item-header {
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 600;
        padding: 16px 12px 8px 12px;
    }

    .sidebar-account {
        padding: 24px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-top: 1px solid var(--border-color);
        background-color: var(--bg-card);
    }

    .account-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .account-avatar {
        width: 40px;
        height: 40px;
        background-color: var(--bg-card-alt);
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        color: var(--text-muted);
    }

    .account-details {
        display: flex;
        flex-direction: column;
    }

    .account-name {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .account-email {
        font-size: 12px;
        color: var(--text-muted);
    }

    .logout-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        padding: 8px;
        border-radius: 4px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: color 0.2s ease, background-color 0.2s ease;
    }

    .logout-btn:hover {
        color: rgb(255, 107, 107);
        background-color: rgba(255, 107, 107, 0.1);
    }

    .main-content {
        margin-left: 312px;
        width: calc(100% - 312px);
        background-color: var(--bg-page);
        min-height: 100vh;
        transition: margin-left 0.3s ease, width 0.3s ease, background-color 0.3s ease;
        padding-top: 0;
    }

    .main-content-unauth {
        width: 100%;
        background-color: var(--bg-page);
        min-height: 100vh;
        padding-top: 0;
    }

    .top-app-bar {
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding: 0 24px;
        background-color: var(--bg-page); /* Solid background to hide content scrolling under it */
        position: sticky; /* Keep it visible at the top while scrolling */
        top: 0;
        z-index: 90;
    }

    .spacer {
        flex-grow: 1;
    }

    .notification-bell {
        color: var(--text-primary);
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        transition: background-color 0.2s ease;
    }

    .notification-bell:hover {
        background-color: var(--bg-card-alt);
    }

    /* Mobile Responsive Styles */
    @@media (max-width: 992px) {
        .top-app-bar {
            display: none !important;
        }
        
        .sidebar {
            transform: translateX(-100%);
            box-shadow: 5px 0 15px rgba(0, 0, 0, 0.5);
        }

        .sidebar.open {
            transform: translateX(0);
        }

        .main-content {
            margin-left: 0;
            width: 100%;
            padding-top: 60px; /* Space for fixed mobile header */
        }

        .mobile-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            height: 60px;
            background-color: var(--bg-card);
            border-bottom: 1px solid var(--border-color);
            position: fixed; /* Strictly stick to top */
            top: 0;
            left: 0;
            width: 100%;
            z-index: 100; /* Higher z-index to stay above content */
        }

        .mobile-menu-btn {
            background: transparent;
            border: none;
            color: var(--text-primary);
            padding: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 90;
            display: none;
        }

        .sidebar-overlay.open {
            display: block;
        }
    }

    @@media (min-width: 993px) {
        .mobile-header, .sidebar-overlay {
            display: none !important;
        }
    }
</style>

@code {
    private bool _isSidebarOpen = false;
    private string _currentLang = "en";
    private bool _isLoading = true;
    private string? _userName;
    private string? _userEmail;
    private string? _userProfilePictureUrl;

    protected override async Task OnInitializedAsync()
    {
        NavigationRegistry.CurrentManager = NavManager;
        
        try
        {
            var userResult = await ApiClient.GetCurrentUser.ExecuteAsync();
            if (userResult.Data?.CurrentUser != null)
            {
                var user = userResult.Data.CurrentUser;
                _userName = $"{user.FirstName} {user.LastName}";
                _userEmail = user.Email;
                _userProfilePictureUrl = user.ProfilePictureUrl;
                
                var preferredLang = user.PreferredLanguage;
                var currentCulture = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
                
                if (!string.IsNullOrEmpty(preferredLang) && preferredLang != currentCulture)
                {
                    var culture = new System.Globalization.CultureInfo(preferredLang);
                    System.Globalization.CultureInfo.DefaultThreadCurrentCulture = culture;
                    System.Globalization.CultureInfo.DefaultThreadCurrentUICulture = culture;
                    _currentLang = preferredLang;
                    
                    // We force reload the page to apply localization strings globally
                    NavManager.NavigateTo(NavManager.Uri, forceLoad: true);
                    return;
                }
                
                _currentLang = !string.IsNullOrEmpty(preferredLang) ? preferredLang : currentCulture;
            }
            else
            {
                _currentLang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainLayout] Error loading user profile: {ex.Message}");
            _currentLang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleSidebar()
    {
        _isSidebarOpen = !_isSidebarOpen;
    }

    private void CloseSidebar()
    {
        _isSidebarOpen = false;
    }

    private void Navigate(string route)
    {
        CloseSidebar();
        NavigationBridge.NavigateToAsync(route);
    }

    private async Task LogoutAsync()
    {
        await AuthService.ClearTokenAsync();
        
        // Notify the Blazor authentication system that the user is now anonymous
        if (AuthStateProvider is MauiAuthenticationStateProvider mauiProvider)
        {
            mauiProvider.NotifyAuthenticationStateChanged();
        }
        
        await BuildSmart.SharedUI.MauiMocks.MainThread.InvokeOnMainThreadAsync(() =>
        {
            // Logout logic should be abstracted. For now, navigate to root.
            NavigationBridge.NavigateToAsync("//LoginPage");
        });
    }
}


